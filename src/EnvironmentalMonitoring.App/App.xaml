<Application x:Class="EnvironmentalMonitoring.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EnvironmentalMonitoring.App"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <FontFamily x:Key="PretendardVariable">pack://application:,,,/EnvironmentalMonitoring.App;component/Assets/Fonts/#Pretendard Variable</FontFamily>
        <FontFamily x:Key="Pretendard">pack://application:,,,/EnvironmentalMonitoring.App;component/Assets/Fonts/#Pretendard</FontFamily>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource PretendardVariable}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource PretendardVariable}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource PretendardVariable}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="{StaticResource PretendardVariable}" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="{StaticResource PretendardVariable}" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="{StaticResource PretendardVariable}" />
        </Style>
    </Application.Resources>
</Application>
