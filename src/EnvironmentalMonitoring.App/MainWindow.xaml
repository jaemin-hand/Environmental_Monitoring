                    </Grid>
                </Border>

                <Border x:Name="SensorDetailOverlayRoot"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Width="660"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="430,120,0,0"
                        Panel.ZIndex="80"
                        Background="#101B2A"
                        BorderBrush="#A7AFBC"
                        BorderThickness="1.2"
                        CornerRadius="14"
                        Padding="14"
                        Visibility="{Binding SensorDetailVisibility}"
                        Effect="{StaticResource PanelShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <TextBlock Text="{Binding SensorDetailTitle}"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Click="ToggleSensorDetailLimitEditModeButton_Click"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="8,3"
                                        Margin="0,0,6,0"
                                        Cursor="Hand"
                                        ToolTip="{Binding SensorDetailLimitEditButtonToolTip}">
                                    <Grid>
                                        <Viewbox Width="20" Height="20">
                                            <Viewbox.Style>
                                                <Style TargetType="Viewbox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSensorDetailLimitEditMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Viewbox.Style>
                                            <Path Data="M5 4V20M12 4V20M19 4V20M3 9H7M10 15H14M17 8H21"
                                                  Stroke="{StaticResource MutedTextBrush}"
                                                  Style="{StaticResource SvgIconPathStyle}" />
                                        </Viewbox>
                                        <TextBlock Text="저장"
                                                   Foreground="{StaticResource BlueBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSensorDetailLimitEditMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Button>

                                <Button Click="ToggleSensorDetailNameEditModeButton_Click"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="8,3"
                                        Margin="0,0,8,0"
                                        Cursor="Hand"
                                        ToolTip="{Binding SensorDetailNameEditButtonToolTip}">
                                    <Grid>
                                        <Viewbox Width="18" Height="18">
                                            <Viewbox.Style>
                                                <Style TargetType="Viewbox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSensorDetailNameEditMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Viewbox.Style>
                                            <Path Data="M16.862 3.487L18.513 5.138M4 20H7.304L17.688 9.616C18.6 8.704 18.6 7.225 17.688 6.313L17.687 6.312C16.775 5.4 15.296 5.4 14.384 6.312L4 16.696V20Z"
                                                  Stroke="{StaticResource MutedTextBrush}"
                                                  Style="{StaticResource SvgIconPathStyle}" />
                                        </Viewbox>
                                        <TextBlock Text="저장"
                                                   Foreground="{StaticResource BlueBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSensorDetailNameEditMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Button>

                                <TextBlock Text="{Binding SensorDetailRealtimeLabel}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <ItemsControl x:Name="SensorDetailOverlayItemsControl"
                                      Grid.Row="1"
                                      ItemsSource="{Binding SensorDetailItems}"
                                      ItemTemplate="{StaticResource TemperatureDetailSensorCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Margin" Value="7" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- Blocking calibration modal: first-stage one-point offset calibration. -->
            <Grid Grid.Row="0"
                  Grid.RowSpan="6"
                  Panel.ZIndex="110"
                  Background="#C8000000"
                  Visibility="{Binding CalibrationModalVisibility}">
                <Border Width="1640"
                        Height="820"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#0A1422"
                        BorderBrush="#526A88"
                        BorderThickness="1.2"
                        CornerRadius="12"
                        Padding="28,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="58" />
                            <RowDefinition Height="58" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="64" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="교정값 입력 및 보정 적용 관리"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="28"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="3점 기준값 기반 보정"
                                           Foreground="{StaticResource BlueBrush}"
                                           FontSize="17"
                                           Margin="18,10,0,0" />
                            </StackPanel>
                            <Button Content="×"
                                    Click="CloseCalibrationModalButton_Click"
                                    Width="42"
                                    Height="42"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    Foreground="{StaticResource TextBrush}"
                                    BorderThickness="0"
                                    FontSize="32"
                                    Cursor="Hand" />
                        </Grid>

                        <Border Grid.Row="1"
                                Background="#07111E"
                                BorderBrush="#203A58"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18,10"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="현재값을 Raw 값으로 캡처하고, 기준값과 비교해 구간별 선형 보정을 적용합니다."
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="온도 기준값: 0℃ / 20℃ / 40℃, 습도 기준값: 20%RH / 50%RH / 80%RH, 대기압 기준값: 96kPa / 101.3kPa / 105kPa"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="14"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="3개 측정포인트 완료 채널만 적용"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="#2A4360"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="42" />
                                    <RowDefinition Height="38" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="전체 센서 교정값 입력"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="22"
                                           FontWeight="SemiBold" />

                                <Border Grid.Row="1"
                                        Background="#101824"
                                        BorderBrush="#1E334C"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="채널명" Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="현재값" Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="2" Text="보정된 값" Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="3" Text="측정포인트 1~3" Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="4" Text="적용" Style="{StaticResource TableHeaderTextStyle}" HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="2"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Margin="0,8,0,0">
                                    <ItemsControl ItemsSource="{Binding CalibrationItems}"
                                                  ItemTemplate="{StaticResource CalibrationRowTemplateV2}" />
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3"
                              Margin="0,16,0,0">
                            <TextBlock Text="기준값은 기본값을 우선 사용하고, 현장 기준 장비값이 다르면 직접 수정 후 적용합니다."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Content="입력 초기화"
                                        Click="ResetCalibrationInputsButton_Click"
                                        Width="130"
                                        Height="40"
                                        Background="#293241"
                                        Foreground="{StaticResource TextBrush}"
                                        BorderBrush="#3A4658"
                                        BorderThickness="1"
                                        Margin="0,0,10,0"
                                        Cursor="Hand" />
                                <Button Content="닫기"
                                        Click="CloseCalibrationModalButton_Click"
                                        Width="110"
                                        Height="40"
                                        Background="#111827"
                                        Foreground="{StaticResource TextBrush}"
                                        BorderBrush="#526A88"
                                        BorderThickness="1"
                                        Margin="0,0,10,0"
                                        Cursor="Hand" />
                                <Button Content="전체 적용 저장"
                                        Click="SaveCalibrationButton_Click"
                                        Width="150"
                                        Height="40"
                                        Background="#0B2346"
                                        Foreground="{StaticResource BlueBrush}"
                                        BorderBrush="#2D64A0"
                                        BorderThickness="1"
                                        Cursor="Hand" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Blocking history modal: query conditions, graph, and CSV export only. -->
            <Grid Grid.Row="0"
                  Grid.RowSpan="6"
                  Panel.ZIndex="100"
                  Background="#C8000000"
                  Visibility="{Binding HistoryModalVisibility}">
                <Border Width="1680"
                        Height="820"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#0A1422"
                        BorderBrush="#526A88"
                        BorderThickness="1.2"
                        CornerRadius="12"
                        Padding="26"
                        Effect="{StaticResource PanelShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="54" />
                            <RowDefinition Height="104" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="히스토리 조회"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="27"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="DB 저장 데이터 기준"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="15"
                                           Margin="16,7,0,0" />
                            </StackPanel>
                            <Button Content="×"
                                    Click="CloseHistoryModalButton_Click"
                                    Width="42"
                                    Height="42"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="#101D2D"
                                    Foreground="{StaticResource TextBrush}"
                                    BorderBrush="#405675"
                                    BorderThickness="1"
                                    FontSize="27"
                                    Cursor="Hand" />
                        </Grid>

                        <Border Grid.Row="1"
                                Style="{StaticResource PanelStyle}"
                                Padding="22,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="118" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="176" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="조회 기간"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="17"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0" />
                                <DatePicker Grid.Column="1"
                                            SelectedDate="{Binding SelectedReportDate, Mode=TwoWay}"
                                            Height="42"
                                            Background="#07101A"
                                            Foreground="#111827"
                                            BorderBrush="#2E4C75"
                                            BorderThickness="1"
                                            FontSize="16"
                                            VerticalContentAlignment="Center" />
                                <TextBlock Grid.Column="5"
                                           Text="센서"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="17"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0" />
                                <ComboBox Grid.Column="6"
                                          ItemsSource="{Binding HistoryChannelOptions}"
                                          SelectedValue="{Binding SelectedHistoryChannelCode, Mode=TwoWay}"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="Label"
                                          Height="42"
                                          Background="#07101A"
                                          Foreground="#111827"
                                          BorderBrush="#2E4C75"
                                          BorderThickness="1"
                                          FontSize="16"
                                          Padding="10,0" />
                                <Button Grid.Column="8"
                                        Content="조회"
                                        Click="RefreshHistoryButton_Click"
                                        Height="42"
                                        Background="#0B2346"
                                        Foreground="{StaticResource BlueBrush}"
                                        BorderBrush="{StaticResource BlueBrush}"
                                        BorderThickness="1"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Cursor="Hand" />
                                <Button Grid.Column="10"
                                        Content="CSV 내보내기"
                                        Click="ExportReportCsvButton_Click"
                                        Height="42"
                                        Background="#0B1832"
                                        Foreground="{StaticResource BlueBrush}"
                                        BorderBrush="#315BCA"
                                        BorderThickness="1"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Cursor="Hand" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Style="{StaticResource PanelStyle}"
                                Padding="26,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="42" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="히스토리 그래프"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="22"
                                           FontWeight="SemiBold" />

                                <Border Grid.Row="1"
                                        Background="{StaticResource PanelDeepBrush}"
                                        BorderBrush="#203A58"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="22,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="52" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="℃" Foreground="{StaticResource MutedTextBrush}" FontSize="15" />
                                            <TextBlock Text="25.0" Foreground="{StaticResource MutedTextBrush}" FontSize="15" Margin="0,50,0,0" />
                                            <TextBlock Text="23.0" Foreground="{StaticResource MutedTextBrush}" FontSize="15" Margin="0,68,0,0" />
                                            <TextBlock Text="21.0" Foreground="{StaticResource MutedTextBrush}" FontSize="15" Margin="0,68,0,0" />
                                            <TextBlock Text="20.0" Foreground="{StaticResource MutedTextBrush}" FontSize="15" Margin="0,46,0,0" />
                                        </StackPanel>

                                        <Grid Grid.Column="1">
                                            <Viewbox Stretch="Fill"
                                                     Margin="0,0,0,30">
                                                <Canvas Width="760" Height="250">
                                                    <Line X1="0" Y1="22" X2="760" Y2="22" Stroke="#19304A" StrokeThickness="1" StrokeDashArray="3,4" />
                                                    <Line X1="0" Y1="70" X2="760" Y2="70" Stroke="#19304A" StrokeThickness="1" StrokeDashArray="3,4" />
                                                    <Line X1="0" Y1="118" X2="760" Y2="118" Stroke="#19304A" StrokeThickness="1" StrokeDashArray="3,4" />
                                                    <Line X1="0" Y1="166" X2="760" Y2="166" Stroke="#19304A" StrokeThickness="1" StrokeDashArray="3,4" />
                                                    <Line X1="0" Y1="22" X2="0" Y2="214" Style="{StaticResource GraphAxisLineStyle}" />
                                                    <Line X1="0" Y1="214" X2="760" Y2="214" Style="{StaticResource GraphAxisLineStyle}" />

                                                    <ItemsControl ItemsSource="{Binding HistoryTimeAxisTicks}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <Canvas Width="760" Height="250" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemContainerStyle>
                                                            <Style TargetType="ContentPresenter">
                                                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                                <Setter Property="Canvas.Top" Value="0" />
                                                            </Style>
                                                        </ItemsControl.ItemContainerStyle>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Line X1="0"
                                                                      Y1="22"
                                                                      X2="0"
                                                                      Y2="214"
                                                                      Stroke="#162B43"
                                                                      StrokeThickness="0.8"
                                                                      StrokeDashArray="2,5"
                                                                      Opacity="{Binding Opacity}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <Line X1="0"
                                                          X2="760"
                                                          Y1="{Binding HistoryHighAlarmLineY}"
                                                          Y2="{Binding HistoryHighAlarmLineY}"
                                                          Stroke="#FF8A84"
                                                          StrokeThickness="1"
                                                          StrokeDashArray="5,6"
                                                          Visibility="{Binding HistoryHighAlarmLineVisibility}" />
                                                    <TextBlock Canvas.Left="708"
                                                               Canvas.Top="{Binding HistoryHighAlarmLabelY}"
                                                               Text="{Binding HistoryHighAlarmText}"
                                                               Foreground="#FF8A84"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Visibility="{Binding HistoryHighAlarmLineVisibility}" />
                                                    <Line X1="0"
                                                          X2="760"
                                                          Y1="{Binding HistoryLowAlarmLineY}"
                                                          Y2="{Binding HistoryLowAlarmLineY}"
                                                          Stroke="#6E9BFF"
                                                          StrokeThickness="1"
                                                          StrokeDashArray="5,6"
                                                          Visibility="{Binding HistoryLowAlarmLineVisibility}" />
                                                    <TextBlock Canvas.Left="708"
                                                               Canvas.Top="{Binding HistoryLowAlarmLabelY}"
                                                               Text="{Binding HistoryLowAlarmText}"
                                                               Foreground="#6E9BFF"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Visibility="{Binding HistoryLowAlarmLineVisibility}" />

                                                    <Polyline Points="{Binding HistoryTemperatureTrendPoints}"
                                                              Stroke="{StaticResource BlueBrush}"
                                                              StrokeThickness="1.3"
                                                              StrokeLineJoin="Round"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round" />

                                                    <ItemsControl ItemsSource="{Binding HistoryTimeAxisTicks}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <Canvas Width="760" Height="250" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemContainerStyle>
                                                            <Style TargetType="ContentPresenter">
                                                                <Setter Property="Canvas.Left" Value="{Binding LabelX}" />
                                                                <Setter Property="Canvas.Top" Value="220" />
                                                            </Style>
                                                        </ItemsControl.ItemContainerStyle>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Label}"
                                                                           Foreground="{StaticResource MutedTextBrush}"
                                                                           FontSize="10" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <TextBlock Canvas.Left="730"
                                                               Canvas.Top="236"
                                                               Text="time"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               FontSize="11" />
                                                </Canvas>
                                            </Viewbox>

                                            <TextBlock Text="{Binding SelectedReportDate, StringFormat={}{0:yyyy-MM-dd}}"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Bottom"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="15" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Active alarm selector: choose one active alarm before recording the action note. -->
            <Grid Grid.Row="0"
                  Grid.RowSpan="6"
                  Panel.ZIndex="125"
                  Background="#A8000000"
                  Visibility="{Binding AlarmSelectionModalVisibility}">
                <Border Width="720"
                        Height="520"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#0A1422"
                        BorderBrush="#FF4B3E"
                        BorderThickness="1.2"
                        CornerRadius="14"
                        Padding="26"
                        Effect="{StaticResource PanelShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="62" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="52" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="조치할 알람 선택"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="28"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="활성 알람이 여러 건일 경우, 먼저 처리할 알람 1건을 선택합니다."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="14"
                                           Margin="0,5,0,0" />
                            </StackPanel>
                            <Button Content="×"
                                    Click="CloseAlarmSelectionModalButton_Click"
                                    Width="40"
                                    Height="40"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="#121A26"
                                    Foreground="{StaticResource TextBrush}"
                                    BorderBrush="#526A88"
                                    BorderThickness="1"
                                    FontSize="24"
                                    Cursor="Hand" />
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,12,0,14"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ActiveAlarmSelectionItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Tag="{Binding Id}"
                                                Click="SelectAlarmForActionButton_Click"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Margin="0,0,0,10"
                                                Cursor="Hand">
                                            <Border Background="#10141A"
                                                    BorderBrush="#FF4B3E"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="16,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="0"
                                                                   Text="{Binding SelectionTitle}"
                                                                   Foreground="#FFE3DF"
                                                                   FontSize="17"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <StackPanel Orientation="Horizontal"
                                                                    Grid.Row="0"
                                                                    Grid.Column="1"
                                                                    Margin="12,1,0,0"
                                                                    Visibility="{Binding LimitComparisonVisibility}">
                                                            <Viewbox Width="18"
                                                                     Height="18"
                                                                     Margin="0,0,6,0">
                                                                <Grid>
                                                                    <Path Data="M23 6 L13.5 15.5 L8.5 10.5 L1 18 M17 6 L23 6 L23 12"
                                                                          Stroke="{StaticResource RedBrush}">
                                                                        <Path.Style>
                                                                            <Style TargetType="Path" BasedOn="{StaticResource SvgIconPathStyle}">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsAboveLimit}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Path.Style>
                                                                    </Path>
                                                                    <Path Data="M23 18 L13.5 8.5 L8.5 13.5 L1 6 M17 18 L23 18 L23 12"
                                                                          Stroke="{StaticResource RedBrush}">
                                                                        <Path.Style>
                                                                            <Style TargetType="Path" BasedOn="{StaticResource SvgIconPathStyle}">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsBelowLimit}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Path.Style>
                                                                    </Path>
                                                                </Grid>
                                                            </Viewbox>
                                                            <TextBlock Text="{Binding LimitComparisonText}"
                                                                       Foreground="{StaticResource RedBrush}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>

                                                        <TextBlock Grid.Row="1"
                                                                   Grid.ColumnSpan="2"
                                                                   Text="{Binding OccurredAgo}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="13"
                                                                   Margin="0,6,0,0" />
                                                    </Grid>
                                                    <StackPanel Grid.Column="1"
                                                                MinWidth="150"
                                                                HorizontalAlignment="Right"
                                                                Margin="18,0,0,0">
                                                        <TextBlock Text="{Binding ChannelCode}"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   FontSize="15"
                                                                   HorizontalAlignment="Right" />
                                                        <TextBlock Text="{Binding MeasuredValue}"
                                                                   Foreground="{StaticResource RedBrush}"
                                                                   FontSize="19"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Right"
                                                                   Margin="0,5,0,0" />
                                                        <TextBlock Text="{Binding OccurredAt}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12"
                                                                   HorizontalAlignment="Right"
                                                                   Margin="0,5,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Button Grid.Row="2"
                                Content="닫기"
                                Click="CloseAlarmSelectionModalButton_Click"
                                Width="112"
                                Height="40"
                                HorizontalAlignment="Right"
                                Background="#111827"
                                Foreground="{StaticResource TextBrush}"
                                BorderBrush="#526A88"
                                BorderThickness="1"
                                Cursor="Hand" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Blocking alarm action modal: records who handled the selected alarm and what action was taken. -->
            <Grid Grid.Row="0"
                  Grid.RowSpan="6"
                  Panel.ZIndex="130"
                  Background="#B0000000"
                  Visibility="{Binding AlarmActionModalVisibility}">
                <Border Width="720"
                        Height="620"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#0A1422"
                        BorderBrush="#FF4B3E"
                        BorderThickness="1.2"
                        CornerRadius="14"
                        Padding="26"
                        Effect="{StaticResource PanelShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="58" />
                            <RowDefinition Height="192" />
                            <RowDefinition Height="86" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="56" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Content="←"
                                    Click="BackToAlarmSelectionButton_Click"
                                    Width="40"
                                    Height="40"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="#121A26"
                                    Foreground="{StaticResource TextBrush}"
                                    BorderBrush="#526A88"
                                    BorderThickness="1"
                                    FontSize="22"
                                    Cursor="Hand"
                                    ToolTip="알람 선택 목록으로 돌아가기" />

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="14,0,0,0">
                                <TextBlock Text="알람 조치"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="28"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="활성 알람 해지 전 처리자와 조치 내용을 기록합니다."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="14"
                                           Margin="0,5,0,0" />
                            </StackPanel>
                            <Button Content="×"
                                    Click="CloseAlarmActionModalButton_Click"
                                    Grid.Column="2"
                                    Width="40"
                                    Height="40"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="#121A26"
                                    Foreground="{StaticResource TextBrush}"
                                    BorderBrush="#526A88"
                                    BorderThickness="1"
                                    FontSize="24"
                                    Cursor="Hand" />
                        </Grid>

                        <Border Grid.Row="1"
                                Background="#1A1012"
                                BorderBrush="#66322E"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,10"
                                Margin="0,8,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="선택 알람"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="14" />
                                    <TextBlock Text="{Binding AlarmActionTargetTitle}"
                                               Style="{StaticResource AlarmAccentTextStyle}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Margin="0,5,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding AlarmActionTargetDetail}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               Margin="0,4,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,6,0,0"
                                                Visibility="{Binding SelectedAlarmActionItem.LimitComparisonVisibility}">
                                        <Viewbox Width="18"
                                                 Height="18"
                                                 Margin="0,0,6,0">
                                            <Grid>
                                                <Path Data="M23 6 L13.5 15.5 L8.5 10.5 L1 18 M17 6 L23 6 L23 12"
                                                      Stroke="{StaticResource RedBrush}">
                                                    <Path.Style>
                                                        <Style TargetType="Path" BasedOn="{StaticResource SvgIconPathStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedAlarmActionItem.IsAboveLimit}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                                <Path Data="M23 18 L13.5 8.5 L8.5 13.5 L1 6 M17 18 L23 18 L23 12"
                                                      Stroke="{StaticResource RedBrush}">
                                                    <Path.Style>
                                                        <Style TargetType="Path" BasedOn="{StaticResource SvgIconPathStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedAlarmActionItem.IsBelowLimit}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Grid>
                                        </Viewbox>
                                        <TextBlock Text="{Binding SelectedAlarmActionItem.LimitComparisonText}"
                                                   Foreground="{StaticResource RedBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Row="0" Grid.Column="0" Background="#07101A" CornerRadius="6" Padding="9,7" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock Text="상태" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                                <TextBlock Text="{Binding SelectedAlarmActionItem.LifecycleStatusText}" Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="1" Background="#07101A" CornerRadius="6" Padding="9,7" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock Text="기준값" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                                <TextBlock Text="{Binding SelectedAlarmActionItem.ThresholdValueText}" Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="2" Background="#07101A" CornerRadius="6" Padding="9,7" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock Text="발생값" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                                <TextBlock Text="{Binding SelectedAlarmActionItem.TriggerValueText}" Foreground="{StaticResource RedBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="3" Background="#07101A" CornerRadius="6" Padding="9,7" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="최악값" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                                <TextBlock Text="{Binding SelectedAlarmActionItem.WorstValueText}" Foreground="{StaticResource RedBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="0" Background="#07101A" CornerRadius="6" Padding="9,7" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="현재값" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                                <TextBlock Text="{Binding SelectedAlarmActionItem.CurrentValueText}" Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1" Background="#07101A" CornerRadius="6" Padding="9,7" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="복귀값" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                                <TextBlock Text="{Binding SelectedAlarmActionItem.ReturnValueText}" Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="2" Background="#07101A" CornerRadius="6" Padding="9,7" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="복귀시각" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                                <TextBlock Text="{Binding SelectedAlarmActionItem.ReturnedAtText}" Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="3" Background="#07101A" CornerRadius="6" Padding="9,7">
                                            <StackPanel>
                                                <TextBlock Text="발생시각" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                                <TextBlock Text="{Binding SelectedAlarmActionItem.OccurredAt}" Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SelectedAlarmActionItem.Severity}"
                                           Style="{StaticResource AlarmAccentTextStyle}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="18,0,0,0" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="처리자"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="14"
                                       Margin="0,0,0,7" />
                            <TextBox Text="{Binding AlarmActionOperatorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="42"
                                     Background="#07101A"
                                     Foreground="{StaticResource TextBrush}"
                                     BorderBrush="#405675"
                                     BorderThickness="1"
                                     FontSize="17"
                                     Padding="12,0"
                                     VerticalContentAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Row="3">
                            <TextBlock Text="조치 메모"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="14"
                                       Margin="0,0,0,7" />
                            <TextBox Text="{Binding AlarmActionNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="112"
                                     Background="#07101A"
                                     Foreground="{StaticResource TextBrush}"
                                     BorderBrush="#405675"
                                     BorderThickness="1"
                                     FontSize="16"
                                     Padding="12,10"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                            <TextBlock Text="예: 원인 확인 후 환기 상태 점검, 센서값 정상화 확인"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       Margin="2,7,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Row="4"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom">
                            <Button Content="취소"
                                    Click="CloseAlarmActionModalButton_Click"
                                    Width="110"
                                    Height="42"
                                    Background="#111827"
                                    Foreground="{StaticResource TextBrush}"
                                    BorderBrush="#526A88"
                                    BorderThickness="1"
                                    Margin="0,0,12,0"
                                    Cursor="Hand" />
                            <Button Content="조치 완료"
                                    Click="CompleteAlarmActionButton_Click"
                                    Width="136"
                                    Height="42"
                                    Background="#4A1717"
                                    Foreground="#FFE3DF"
                                    BorderBrush="#FF4B3E"
                                    BorderThickness="1"
                                    FontWeight="SemiBold"
                                    Cursor="Hand" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <StackPanel Visibility="Collapsed">
                <Button Tag="realtime" Click="NavigationButton_Click" />
                <Button Tag="log" Click="NavigationButton_Click" />
                <Button Tag="system" Click="NavigationButton_Click" />
            </StackPanel>
        </Grid>
    </Viewbox>
</Window>
