                                                Width="760"
                                                Height="140" />

                                        <Polyline Canvas.Left="48"
                                                  Points="{Binding PressureTrendPoints}"
                                                  Stroke="#B482FF"
                                                  StrokeThickness="1.0"
                                                  StrokeLineJoin="Round"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />
                                        <Line X1="48"
                                              Y1="41"
                                              X2="808"
                                              Y2="41"
                                              Stroke="#E07B79"
                                              StrokeThickness="0.6"
                                              StrokeDashArray="5,4" />
                                        <Line X1="48"
                                              Y1="108"
                                              X2="808"
                                              Y2="108"
                                              Stroke="#5B89E8"
                                              StrokeThickness="0.6"
                                              StrokeDashArray="5,4" />
                                        <TextBlock Canvas.Left="812"
