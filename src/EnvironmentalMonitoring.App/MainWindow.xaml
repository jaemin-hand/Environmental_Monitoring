                                        <TextBlock Canvas.Left="2" Canvas.Top="34" Text="105.0" Style="{StaticResource GraphAxisTextStyle}" />
                                        <TextBlock Canvas.Left="2" Canvas.Top="67" Text="100.0" Style="{StaticResource GraphAxisTextStyle}" />
                                        <TextBlock Canvas.Left="2" Canvas.Top="109" Text="96.0 kPa" Style="{StaticResource GraphAxisTextStyle}" />

