<Window x:Class="EnvironmentalMonitoring.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EnvironmentalMonitoring.App"
        mc:Ignorable="d"
        Title="Environmental Monitoring"
        Width="1820"
        Height="1120"
        MinWidth="1440"
        MinHeight="900"
        Background="{x:Static local:DashboardPalette.WindowBackground}"
        FontFamily="Malgun Gothic">
    <Window.Resources>
        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{x:Static local:DashboardPalette.Surface}" />
            <Setter Property="CornerRadius" Value="24" />
        </Style>

        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{x:Static local:DashboardPalette.TextPrimary}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{x:Static local:DashboardPalette.TextPrimary}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5A5A5A" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="22,18" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#F7F4EE" />
            <Setter Property="BorderBrush" Value="#D4CEC0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="RowBackground" Value="#F7F4EE" />
            <Setter Property="AlternatingRowBackground" Value="#EEE9DD" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20,16"
                Style="{StaticResource PanelCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Margin="0,0,14,0"
                               FontSize="24"
                               FontWeight="Bold"
                               Text="ENV" />
                    <TextBlock VerticalAlignment="Center"
                               Style="{StaticResource HeaderTextStyle}"
                               Text="{Binding WindowTitle}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="18,10"
                        Background="#B5D99E"
                        CornerRadius="22">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Text="{Binding CurrentTimeText}" />
                </Border>
            </Grid>
        </Border>

        <ItemsControl Grid.Row="2"
                      ItemsSource="{Binding StatusCards}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,18,0"
                            Padding="22,16"
                            Background="{Binding Background}"
                            CornerRadius="22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="16"
                                           Foreground="#3C3A38"
                                           Text="{Binding Title}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Text="{Binding Summary}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="13"
                                           Foreground="#403D3B"
                                           Text="{Binding Detail}" />
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Text="{Binding IconText}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="0,18,0,18"
                    Style="{StaticResource PanelCardStyle}">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Bottom"
                                Margin="24,12,24,0">
                        <Border Height="1"
                                Background="#AEAEAE" />

                        <Button Tag="{Binding SettingsMenuItem.Key}"
                                Style="{StaticResource MenuButtonStyle}"
                                Background="{Binding SettingsMenuItem.Background}"
                                Click="NavigationButton_Click">
                            <TextBlock FontSize="22"
                                       Text="{Binding SettingsMenuItem.Title}" />
                        </Button>

                        <TextBlock Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource SubtleTextStyle}"
                                   Text="{Binding FooterStatusMessage}" />
                    </StackPanel>

                    <StackPanel Margin="0,20,0,0">
                        <ItemsControl ItemsSource="{Binding MainMenuItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Tag="{Binding Key}"
                                            Style="{StaticResource MenuButtonStyle}"
                                            Background="{Binding Background}"
                                            Click="NavigationButton_Click">
                                        <TextBlock FontSize="22"
                                                   Text="{Binding Title}" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid Visibility="{Binding DashboardViewVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="540" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="22"
                            Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="시험실 센서 배치도" />
                            <TextBlock Margin="0,8,0,16"
                                       Style="{StaticResource SubtleTextStyle}"
                                       Text="채널별 현재 보정값 기준 상태를 표시합니다." />

                            <ItemsControl ItemsSource="{Binding SensorTiles}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"
                                                   ItemWidth="235"
                                                   ItemHeight="138" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,18,18"
                                                Padding="16"
                                                Background="{Binding Background}"
                                                CornerRadius="20">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="24"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding DisplayText}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="250" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="22"
                                Style="{StaticResource PanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                                               Text="평균 온도 / 습도 추이" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource SubtleTextStyle}"
                                               Text="{Binding RealtimeSummary}" />
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Margin="0,18,0,10"
                                        BorderBrush="#D2CEC3"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Grid>
                                        <UniformGrid Rows="6">
                                            <Border BorderBrush="#E7E1D5" BorderThickness="0,0,0,1" />
                                            <Border BorderBrush="#E7E1D5" BorderThickness="0,0,0,1" />
                                            <Border BorderBrush="#E7E1D5" BorderThickness="0,0,0,1" />
                                            <Border BorderBrush="#E7E1D5" BorderThickness="0,0,0,1" />
                                            <Border BorderBrush="#E7E1D5" BorderThickness="0,0,0,1" />
                                            <Border BorderBrush="#E7E1D5" BorderThickness="0,0,0,1" />
                                        </UniformGrid>

                                        <Canvas Margin="30,18,30,28"
                                                ClipToBounds="True">
                                            <Polyline Points="{Binding TemperatureTrendPoints}"
                                                      Stroke="{x:Static local:DashboardPalette.TempLine}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            <Polyline Points="{Binding HumidityTrendPoints}"
                                                      Stroke="{x:Static local:DashboardPalette.HumidityLine}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            <Line X1="760"
                                                  Y1="0"
                                                  X2="760"
                                                  Y2="220"
                                                  Stroke="#2C2C2C"
                                                  StrokeThickness="2" />
                                        </Canvas>
                                    </Grid>
                                </Border>

                                <UniformGrid Grid.Row="2"
                                             Columns="6">
                                    <TextBlock HorizontalAlignment="Left" Text="04:00" />
                                    <TextBlock HorizontalAlignment="Center" Text="06:00" />
                                    <TextBlock HorizontalAlignment="Center" Text="08:00" />
                                    <TextBlock HorizontalAlignment="Center" Text="10:00" />
                                    <TextBlock HorizontalAlignment="Center" Text="12:00" />
                                    <TextBlock HorizontalAlignment="Right" Text="Now" />
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Padding="20,16"
                                Background="{x:Static local:DashboardPalette.DarkPanel}"
                                CornerRadius="24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ItemsControl ItemsSource="{Binding RecentEvents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Width="10"
                                                            Height="10"
                                                            CornerRadius="99"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding Accent}" />
                                                    <TextBlock Grid.Column="2"
                                                               FontSize="18"
                                                               Foreground="White"
                                                               Text="{Binding TimestampText}" />
                                                    <TextBlock Grid.Column="3"
                                                               Margin="12,0,0,0"
                                                               FontSize="18"
                                                               Foreground="White"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding Message}" />
                                                </Grid>
                                                <Border Height="1"
                                                        Margin="0,0,0,12"
                                                        Background="{x:Static local:DashboardPalette.EventBorder}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Grid.Row="1"
                                           HorizontalAlignment="Right"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="최근 알람 및 이벤트" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Visibility="{Binding RealtimeViewVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="250" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="430" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="22"
                                Style="{StaticResource PanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                                               Text="실시간 추이 그래프" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource SubtleTextStyle}"
                                               Text="{Binding RealtimeSummary}" />
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Margin="0,18,0,0"
                                        BorderBrush="#D2CEC3"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Grid>
                                        <UniformGrid Rows="6">
                                            <Border BorderBrush="#E7E1D5" BorderThickness="0,0,0,1" />
                                            <Border BorderBrush="#E7E1D5" BorderThickness="0,0,0,1" />
                                            <Border BorderBrush="#E7E1D5" BorderThickness="0,0,0,1" />
                                            <Border BorderBrush="#E7E1D5" BorderThickness="0,0,0,1" />
                                            <Border BorderBrush="#E7E1D5" BorderThickness="0,0,0,1" />
                                            <Border BorderBrush="#E7E1D5" BorderThickness="0,0,0,1" />
                                        </UniformGrid>

                                        <Canvas Margin="30,18,30,28"
                                                ClipToBounds="True">
                                            <Polyline Points="{Binding TemperatureTrendPoints}"
                                                      Stroke="{x:Static local:DashboardPalette.TempLine}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            <Polyline Points="{Binding HumidityTrendPoints}"
                                                      Stroke="{x:Static local:DashboardPalette.HumidityLine}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            <Line X1="760"
                                                  Y1="0"
                                                  X2="760"
                                                  Y2="220"
                                                  Stroke="#2C2C2C"
                                                  StrokeThickness="2" />
                                        </Canvas>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="22"
                                Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="최신 채널 상태" />
                                <TextBlock Margin="0,8,0,12"
                                           Style="{StaticResource SubtleTextStyle}"
                                           Text="보정 적용값과 품질 상태를 함께 표시합니다." />
                                <DataGrid ItemsSource="{Binding LiveChannelItems}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="채널"
                                                            Binding="{Binding ChannelCode}"
                                                            Width="110" />
                                        <DataGridTextColumn Header="측정값"
                                                            Binding="{Binding Value}"
                                                            Width="140" />
                                        <DataGridTextColumn Header="상태"
                                                            Binding="{Binding Quality}"
                                                            Width="120" />
                                        <DataGridTextColumn Header="시각"
                                                            Binding="{Binding SampledAt}"
                                                            Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Padding="22"
                            Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="실시간 센서 배치" />
                            <ItemsControl Margin="0,18,0,0"
                                          ItemsSource="{Binding SensorTiles}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"
                                                   ItemWidth="220"
                                                   ItemHeight="110" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,16,14"
                                                Padding="16"
                                                Background="{Binding Background}"
                                                CornerRadius="20">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding DisplayText}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Padding="24,22"
                        Style="{StaticResource PanelCardStyle}"
                        Visibility="{Binding HistoryViewVisibility}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal">
                                <DatePicker Width="150"
                                            Margin="0,0,10,0"
                                            SelectedDate="{Binding SelectedReportDate}" />
                                <ComboBox Width="180"
                                          Margin="0,0,10,0"
                                          ItemsSource="{Binding HistoryChannelOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedHistoryChannelCode}" />
                                <Button Width="140"
                                        Height="36"
                                        Margin="0,0,10,0"
                                        Background="#DCDCDC"
                                        BorderThickness="0"
                                        Click="ExportReportCsvButton_Click"
                                        Content="CSV 리포트" />
                                <Button Width="140"
                                        Height="36"
                                        Background="#86FF57"
                                        BorderThickness="0"
                                        Click="ExportReportTextButton_Click"
                                        Content="TXT 요약" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="이력 조회" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource SubtleTextStyle}"
                                           Text="{Binding SampleHistorySummary}" />
                                <TextBlock Margin="0,4,0,0"
                                           Style="{StaticResource SubtleTextStyle}"
                                           Text="{Binding ReportExportStatusMessage}" />
                            </StackPanel>
                        </DockPanel>

                        <DataGrid ItemsSource="{Binding SampleHistoryItems}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="시각"
                                                    Binding="{Binding SampledAt}"
                                                    Width="180" />
                                <DataGridTextColumn Header="채널"
                                                    Binding="{Binding ChannelCode}"
                                                    Width="140" />
                                <DataGridTextColumn Header="종류"
                                                    Binding="{Binding Kind}"
                                                    Width="100" />
                                <DataGridTextColumn Header="Raw"
                                                    Binding="{Binding RawValue}"
                                                    Width="120" />
                                <DataGridTextColumn Header="보정값"
                                                    Binding="{Binding CorrectedValue}"
                                                    Width="120" />
                                <DataGridTextColumn Header="상태"
                                                    Binding="{Binding Quality}"
                                                    Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Padding="24,22"
                        Style="{StaticResource PanelCardStyle}"
                        Visibility="{Binding AlarmViewVisibility}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal">
                                <DatePicker Width="150"
                                            Margin="0,0,10,0"
                                            SelectedDate="{Binding SelectedAlarmDate}" />
                                <ComboBox Width="180"
                                          Margin="0,0,10,0"
                                          ItemsSource="{Binding AlarmChannelOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedAlarmChannelCode}" />
                                <ComboBox Width="150"
                                          Margin="0,0,10,0"
                                          ItemsSource="{Binding AlarmStatusOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedAlarmStatus}" />
                                <Button Width="180"
                                        Height="36"
                                        Margin="0,0,10,0"
                                        Background="#DCDCDC"
                                        BorderThickness="0"
                                        IsEnabled="{Binding CanAcknowledgeSelectedAlarm}"
                                        Click="AcknowledgeSelectedAlarmButton_Click"
                                        Content="선택 알람 확인" />
                                <Button Width="180"
                                        Height="36"
                                        Background="#86FF57"
                                        BorderThickness="0"
                                        Click="AcknowledgeAllActiveAlarmsButton_Click"
                                        Content="활성 알람 일괄 확인" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="알람 이력" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource SubtleTextStyle}"
                                           Text="{Binding AlarmHistorySummary}" />
                            </StackPanel>
                        </DockPanel>

                        <DataGrid ItemsSource="{Binding AlarmHistoryItems}"
                                  SelectedItem="{Binding SelectedAlarmHistoryItem}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="발생 시각"
                                                    Binding="{Binding OccurredAt}"
                                                    Width="160" />
                                <DataGridTextColumn Header="확인 시각"
                                                    Binding="{Binding AcknowledgedAt}"
                                                    Width="160" />
                                <DataGridTextColumn Header="해제 시각"
                                                    Binding="{Binding ResolvedAt}"
                                                    Width="160" />
                                <DataGridTextColumn Header="채널"
                                                    Binding="{Binding ChannelCode}"
                                                    Width="130" />
                                <DataGridTextColumn Header="알람 종류"
                                                    Binding="{Binding AlarmType}"
                                                    Width="120" />
                                <DataGridTextColumn Header="심각도"
                                                    Binding="{Binding Severity}"
                                                    Width="90" />
                                <DataGridTextColumn Header="측정값"
                                                    Binding="{Binding MeasuredValue}"
                                                    Width="100" />
                                <DataGridTextColumn Header="메시지"
                                                    Binding="{Binding Message}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Padding="24,22"
                        Style="{StaticResource PanelCardStyle}"
                        Visibility="{Binding SettingsViewVisibility}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="설정" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource SubtleTextStyle}"
                                       Text="{Binding RuntimeSettingsFilePath}" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource SubtleTextStyle}"
                                       Text="{Binding EffectiveDataStoragePath}" />
                            <TextBlock Margin="0,4,0,18"
                                       Style="{StaticResource SubtleTextStyle}"
                                       Text="샘플링 주기, 통신 설정, 채널별 보정/알람 기준을 저장할 수 있습니다." />

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="240" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Text="샘플링 주기" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding SamplingModes}"
                                          SelectedItem="{Binding SelectedSamplingMode}"
                                          FontSize="16"
                                          Padding="8,4" />

                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Text="데이터 루트" />
                                <TextBox Grid.Column="3"
                                         Text="{Binding SettingsDataRoot}"
                                         FontSize="16"
                                         Padding="8,4" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Text="게이트웨이 모드" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Text="{Binding SettingsGatewayMode}"
                                         FontSize="16"
                                         Padding="8,4" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Text="테스트 프로필" />
                                <StackPanel Grid.Row="2"
                                            Grid.Column="3"
                                            Orientation="Horizontal">
                                    <TextBox Width="150"
                                             Text="{Binding SettingsPlaceholderProfile}"
                                             FontSize="16"
                                             Padding="8,4" />
                                    <TextBox Width="70"
                                             Margin="10,0,0,0"
                                             Text="{Binding SettingsPlaceholderCycleSeconds}"
                                             FontSize="16"
                                             Padding="8,4" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="장비 통신 설정" />
                            <DataGrid Margin="0,12,0,22"
                                      ItemsSource="{Binding DeviceSettingsItems}"
                                      IsReadOnly="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Key"
                                                        Binding="{Binding Key}"
                                                        IsReadOnly="True"
                                                        Width="140" />
                                    <DataGridTextColumn Header="표시명"
                                                        Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*" />
                                    <DataGridTextColumn Header="IP"
                                                        Binding="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="220" />
                                    <DataGridTextColumn Header="Port"
                                                        Binding="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="채널 기준 설정" />
                            <DataGrid Margin="0,12,0,22"
                                      ItemsSource="{Binding ChannelSettingsItems}"
                                      IsReadOnly="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="채널"
                                                        Binding="{Binding Code}"
                                                        IsReadOnly="True"
                                                        Width="110" />
                                    <DataGridTextColumn Header="표시명"
                                                        Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="190" />
                                    <DataGridTextColumn Header="위치명"
                                                        Binding="{Binding LocationName, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="180" />
                                    <DataGridTextColumn Header="목표값"
                                                        Binding="{Binding TargetValue, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="100" />
                                    <DataGridTextColumn Header="편차 기준"
                                                        Binding="{Binding DeviationThreshold, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="100" />
                                    <DataGridTextColumn Header="하한값"
                                                        Binding="{Binding LowAlarmLimit, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="100" />
                                    <DataGridTextColumn Header="상한값"
                                                        Binding="{Binding HighAlarmLimit, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="100" />
                                    <DataGridTextColumn Header="Scale"
                                                        Binding="{Binding CalibrationScale, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="90" />
                                    <DataGridTextColumn Header="Offset"
                                                        Binding="{Binding Offset, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Width="120"
                                        Height="42"
                                        Margin="0,0,12,0"
                                        Background="#E0E0E0"
                                        BorderThickness="0"
                                        Click="ReloadSettingsButton_Click"
                                        Content="다시 불러오기" />
                                <Button Width="140"
                                        Height="42"
                                        Background="#86FF57"
                                        BorderThickness="0"
                                        Click="SaveSettingsButton_Click"
                                        Content="설정 저장" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
