<Window x:Class="EnvironmentalMonitoring.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Environmental Monitoring"
        Width="1920"
        Height="1080"
        MinWidth="1280"
        MinHeight="720"
        Background="#07101B"
        FontFamily="{StaticResource PretendardVariable}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#07101B" />
        <SolidColorBrush x:Key="PanelBrush" Color="#101B2A" />
        <SolidColorBrush x:Key="PanelDeepBrush" Color="#07101A" />
        <SolidColorBrush x:Key="HeaderBrush" Color="#0C1625" />
        <SolidColorBrush x:Key="BorderBrush" Color="#3B516B" />
        <SolidColorBrush x:Key="SubtleBorderBrush" Color="#1B2B3E" />
        <SolidColorBrush x:Key="TextBrush" Color="#EFF4FF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B5BECF" />
        <SolidColorBrush x:Key="BlueBrush" Color="#55A2FF" />
        <SolidColorBrush x:Key="CyanBrush" Color="#43D0D0" />
        <SolidColorBrush x:Key="PurpleBrush" Color="#B482FF" />
        <SolidColorBrush x:Key="GreenBrush" Color="#65E178" />
        <SolidColorBrush x:Key="RedBrush" Color="#FF423B" />
        <SolidColorBrush x:Key="AmberBrush" Color="#FFB02E" />

        <LinearGradientBrush x:Key="PanelGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#142236" Offset="0" />
            <GradientStop Color="#08131F" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#101D31" Offset="0" />
            <GradientStop Color="#060D17" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AlarmGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2B1620" Offset="0" />
            <GradientStop Color="#492121" Offset="1" />
        </LinearGradientBrush>

        <DropShadowEffect x:Key="PanelShadow" BlurRadius="18" ShadowDepth="0" Color="#000000" Opacity="0.28" />
        <DropShadowEffect x:Key="BlueGlow" BlurRadius="14" ShadowDepth="0" Color="#287BFF" Opacity="0.38" />
        <DropShadowEffect x:Key="RedGlow" BlurRadius="16" ShadowDepth="0" Color="#FF2F25" Opacity="0.45" />

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelGradientBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
        </Style>

        <Style x:Key="AlarmCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelGradientBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="#3B516B" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasActiveAlarm}" Value="True">
                    <Setter Property="Background" Value="{StaticResource AlarmGradientBrush}" />
                    <Setter Property="Effect" Value="{StaticResource RedGlow}" />
                    <Setter Property="BorderBrush">
                        <Setter.Value>
                            <SolidColorBrush Color="#FF423B" />
                        </Setter.Value>
                    </Setter>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Name="AlarmCardBlinkStoryboard">
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                From="#FF423B"
                                                To="#8A211D"
                                                Duration="0:0:0.55"
                                                AutoReverse="True"
                                                RepeatBehavior="Forever" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <RemoveStoryboard BeginStoryboardName="AlarmCardBlinkStoryboard" />
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AlarmAccentTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasActiveAlarm}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,3" />
            <Setter Property="Padding" Value="42,0" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="Height" Value="44" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PeriodButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="#080C14" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActivePeriodButtonStyle" TargetType="Button" BasedOn="{StaticResource PeriodButtonStyle}">
            <Setter Property="Background" Value="#CBD4EF" />
            <Setter Property="Foreground" Value="#111827" />
        </Style>

        <Style x:Key="TinyCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SvgIconPathStyle" TargetType="Path">
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Fill" Value="Transparent" />
        </Style>

        <Style x:Key="GraphGridLineStyle" TargetType="Line">
            <Setter Property="Stroke" Value="#1A2635" />
            <Setter Property="StrokeThickness" Value="0.7" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="GraphAxisLineStyle" TargetType="Line">
            <Setter Property="Stroke" Value="#54677E" />
            <Setter Property="StrokeThickness" Value="1.1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="GraphAxisTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#718096" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#718096" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <DataTemplate x:Key="CalibrationRowTemplate">
            <Border Background="#070B12"
                    BorderBrush="#1E334C"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,10"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="145" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="160" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="17"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding KindText}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding LocationName}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="현재값"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12" />
                        <TextBlock Text="{Binding CurrentValueText}"
                                   Foreground="{StaticResource BlueBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,3,0,0" />
                        <TextBlock Text="{Binding QualityText}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <ItemsControl Grid.Column="2"
                                  ItemsSource="{Binding Points}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="250"
                                        Background="#0B111B"
                                        BorderBrush="#243B58"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,10,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="24" />
                                            <RowDefinition Height="26" />
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="30" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding StatusBrush}"
                                                       HorizontalAlignment="Right"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding RawValueDetailText}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />

                                        <TextBox Grid.Row="2"
                                                 Text="{Binding ReferenceValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30"
                                                 Padding="8,0"
                                                 Background="#D8DCE7"
                                                 Foreground="#111827"
                                                 BorderBrush="#8C95A8"
                                                 BorderThickness="1"
                                                 FontSize="14"
                                                 VerticalContentAlignment="Center" />

                                        <StackPanel Grid.Row="3"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,6,0,0">
                                            <Button Content="캡처"
                                                    Click="CaptureCalibrationPointButton_Click"
                                                    Width="56"
                                                    Height="24"
                                                    Background="#0B2346"
                                                    Foreground="{StaticResource BlueBrush}"
                                                    BorderBrush="#2D64A0"
                                                    BorderThickness="1"
                                                    FontSize="12"
                                                    Cursor="Hand" />
                                            <Button Content="삭제"
                                                    Click="ClearCalibrationPointButton_Click"
                                                    Width="56"
                                                    Height="24"
                                                    Margin="6,0,0,0"
                                                    Background="#1C2026"
                                                    Foreground="{StaticResource MutedTextBrush}"
                                                    BorderBrush="#3A4658"
                                                    BorderThickness="1"
                                                    FontSize="12"
                                                    Cursor="Hand" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Column="3"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <TextBlock Text="보정 후 현재값"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding PreviewValueText}"
                                   Foreground="{StaticResource GreenBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   Margin="0,3,0,0" />
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{Binding StatusBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CalibrationRowTemplateV2">
            <Border Background="#070B12"
                    BorderBrush="#1E334C"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,10"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding KindText}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding LocationName}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="현재값"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12" />
                        <TextBlock Text="{Binding CurrentValueText}"
                                   Foreground="{StaticResource BlueBrush}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Margin="0,3,0,0" />
                        <TextBlock Text="{Binding QualityText}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">
                        <TextBlock Text="보정된 값"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12" />
                        <TextBlock Text="{Binding PreviewValueText}"
                                   Foreground="{StaticResource GreenBrush}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Margin="0,3,0,0" />
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{Binding StatusBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <ItemsControl Grid.Column="3"
                                  ItemsSource="{Binding Points}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="215"
                                        Background="#0B111B"
                                        BorderBrush="#243B58"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="9"
                                        Margin="0,0,8,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="24" />
                                            <RowDefinition Height="24" />
                                            <RowDefinition Height="32" />
                                            <RowDefinition Height="28" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding StatusBrush}"
                                                       HorizontalAlignment="Right"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding RawValueDetailText}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />

                                        <TextBox Grid.Row="2"
                                                 Text="{Binding ReferenceValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="28"
                                                 Padding="8,0"
                                                 Background="#D8DCE7"
                                                 Foreground="#111827"
                                                 BorderBrush="#8C95A8"
                                                 BorderThickness="1"
                                                 FontSize="13"
                                                 VerticalContentAlignment="Center" />

                                        <StackPanel Grid.Row="3"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,5,0,0">
                                            <Button Content="캡처"
                                                    Click="CaptureCalibrationPointButton_Click"
                                                    Width="52"
                                                    Height="23"
                                                    Background="#0B2346"
                                                    Foreground="{StaticResource BlueBrush}"
                                                    BorderBrush="#2D64A0"
                                                    BorderThickness="1"
                                                    FontSize="11"
                                                    Cursor="Hand" />
                                            <Button Content="초기화"
                                                    Click="ClearCalibrationPointButton_Click"
                                                    Width="58"
                                                    Height="23"
                                                    Margin="6,0,0,0"
                                                    Background="#1C2026"
                                                    Foreground="{StaticResource MutedTextBrush}"
                                                    BorderBrush="#3A4658"
                                                    BorderThickness="1"
                                                    FontSize="11"
                                                    Cursor="Hand" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Column="4"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <Button Content="적용"
                                Click="ApplyCalibrationChannelButton_Click"
                                Width="92"
                                Height="34"
                                Background="#0B2346"
                                Foreground="{StaticResource BlueBrush}"
                                BorderBrush="#2D64A0"
                                BorderThickness="1"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Cursor="Hand" />
                        <Button Content="교정 초기화"
                                Click="ResetCalibrationChannelButton_Click"
                                Width="92"
                                Height="30"
                                Margin="0,8,0,0"
                                Background="#2A1F24"
                                Foreground="#FFB4AB"
                                BorderBrush="#7A3434"
                                BorderThickness="1"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Cursor="Hand" />
                        <TextBlock Text="{Binding CompletedPointCount, StringFormat={}{0}/3 완료}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SensorCardTemplate">
            <Border Background="#070B12"
                    BorderBrush="{Binding Border}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Ellipse Width="9"
                                 Height="9"
                                 Fill="{Binding ChannelAccent}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,7,0" />
                        <TextBlock Text="{Binding Title}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{Binding Accent}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,1,8,0" />
                        <Viewbox Width="20"
                                 Height="20"
                                 Margin="0,-1,0,0">
                            <Viewbox.Style>
                                <Style TargetType="Viewbox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Viewbox.Style>
                            <Grid>
                                <Path Data="M7.5 12L10.5 15L16.5 9M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z"
                                      Stroke="{Binding Accent}"
                                      Visibility="{Binding CheckIconVisibility}"
                                      Style="{StaticResource SvgIconPathStyle}" />
                                <Path Data="M12 9V13M12 17H12.01M10.29 3.86L1.82 18A2 2 0 0 0 3.54 21H20.46A2 2 0 0 0 22.18 18L13.71 3.86A2 2 0 0 0 10.29 3.86Z"
                                      Stroke="{Binding Accent}"
                                      Visibility="{Binding WarningIconVisibility}"
                                      Style="{StaticResource SvgIconPathStyle}" />
                            </Grid>
                        </Viewbox>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding Value}"
                                   Foreground="{Binding Accent}"
                                   FontSize="25"
                                   FontWeight="Light" />
                        <TextBlock Text="{Binding Unit}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="12"
                                   Margin="4,11,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TemperatureDetailSensorCardTemplate">
            <Border Background="#070B12"
                    BorderBrush="{Binding Border}"
                    BorderThickness="1"
                    CornerRadius="6"
                    MinHeight="82"
                    Padding="12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="9"
                                 Height="9"
                                 Fill="{Binding ChannelAccent}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,7,0" />
                        <TextBlock Text="{Binding Title}"
                                   Grid.Column="1"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsSensorDetailNameEditMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding EditableTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Column="1"
                                 Tag="Name"
                                 Width="92"
                                 Height="22"
                                 Padding="5,0"
                                 HorizontalAlignment="Left"
                                 Background="#D8DCE7"
                                 Foreground="#111827"
                                 BorderBrush="#8C95A8"
                                 BorderThickness="1"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 VerticalContentAlignment="Center">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsSensorDetailNameEditMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{Binding Accent}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,1,8,0" />
                        <Viewbox Width="20"
                                 Height="20"
                                 Margin="0,-1,0,0">
                            <Viewbox.Style>
