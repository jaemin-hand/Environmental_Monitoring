<Window x:Class="EnvironmentalMonitoring.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EnvironmentalMonitoring.App"
        mc:Ignorable="d"
        Title="Environmental Monitoring"
        Width="1820"
        Height="1120"
        MinWidth="1180"
        MinHeight="760"
        Background="{x:Static local:DashboardPalette.WindowBackground}"
        FontFamily="Malgun Gothic">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#10141A" />
        <SolidColorBrush x:Key="SideBarBrush" Color="#181C22" />
        <SolidColorBrush x:Key="CardBrush" Color="#1C2026" />
        <SolidColorBrush x:Key="CardLowBrush" Color="#0A0E14" />
        <SolidColorBrush x:Key="CardHighBrush" Color="#262A31" />
        <SolidColorBrush x:Key="BorderBrush" Color="#31353C" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#DFE2EB" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9DA3AF" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#ABC9EF" />
        <SolidColorBrush x:Key="GoodBrush" Color="#4AE183" />
        <SolidColorBrush x:Key="WarnBrush" Color="#FFB4AB" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="NavIconStyle" TargetType="Path">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#77808E" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C2026" />
                    <Setter Property="Foreground" Value="#DFE2EB" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="#C8D6FF" />
            <Setter Property="Foreground" Value="#10141A" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#31353C" />
            <Setter Property="Foreground" Value="#DFE2EB" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#31353C" />
            <Setter Property="Foreground" Value="#DFE2EB" />
            <Setter Property="BorderBrush" Value="#45474D" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#31353C" />
            <Setter Property="Foreground" Value="#DFE2EB" />
            <Setter Property="BorderBrush" Value="#45474D" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#181C22" />
            <Setter Property="Foreground" Value="#DFE2EB" />
            <Setter Property="BorderBrush" Value="#31353C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#31353C" />
            <Setter Property="RowBackground" Value="#1C2026" />
            <Setter Property="AlternatingRowBackground" Value="#181C22" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SideBarBrush}"
                BorderBrush="#222832"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top"
                            Margin="22,28,22,0">
                    <TextBlock Foreground="#D7E6FF"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="환경 모니터링" />
                    <TextBlock Margin="0,4,0,34"
                               Foreground="#8F9097"
                               FontSize="12"
                               Text="Dynamo Lab Monitor" />

                    <Button x:Name="DashboardNavButton"
                            Tag="dashboard"
                            Margin="0,0,0,8"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavigationButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Style="{StaticResource NavIconStyle}"
                                  Data="M10 6V0H18V6H10ZM0 10V0H8V10H0ZM10 18V8H18V18H10ZM0 18V12H8V18H0Z" />
                            <TextBlock Text="개요" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="HistoryNavButton"
                            Tag="history"
                            Margin="0,0,0,8"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavigationButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Style="{StaticResource NavIconStyle}"
                                  Data="M0 8V0H8V8H0ZM0 18V10H8V18H0ZM10 8V0H18V8H10ZM10 18V10H18V18H10ZM2 6H6V2H2V6ZM12 6H16V2H12V6ZM12 16H16V12H12V16ZM2 16H6V12H2V16Z" />
                            <TextBlock Text="이력 조회" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="AlarmNavButton"
                            Tag="alarm"
                            Margin="0,0,0,8"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavigationButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Style="{StaticResource NavIconStyle}"
                                  Data="M2.925 14.15C2.025 13.2333 1.3125 12.1708 0.7875 10.9625C0.2625 9.75417 0 8.45833 0 7.075C0 5.675 0.2625 4.37083 0.7875 3.1625C1.3125 1.95417 2.025 0.9 2.925 0L4.35 1.425C3.61667 2.15833 3.04167 3.00833 2.625 3.975C2.20833 4.94167 2 5.975 2 7.075C2 8.19167 2.20833 9.23333 2.625 10.2C3.04167 11.1667 3.61667 12.0083 4.35 12.725L2.925 14.15ZM5.75 11.325C5.21667 10.775 4.79167 10.1375 4.475 9.4125C4.15833 8.6875 4 7.90833 4 7.075C4 6.225 4.15833 5.4375 4.475 4.7125C4.79167 3.9875 5.21667 3.35833 5.75 2.825L7.175 4.25C6.80833 4.61667 6.52083 5.04167 6.3125 5.525C6.10417 6.00833 6 6.525 6 7.075C6 7.625 6.10417 8.14167 6.3125 8.625C6.52083 9.10833 6.80833 9.53333 7.175 9.9L5.75 11.325ZM10 9.075C9.45 9.075 8.97917 8.87917 8.5875 8.4875C8.19583 8.09583 8 7.625 8 7.075C8 6.525 8.19583 6.05417 8.5875 5.6625C8.97917 5.27083 9.45 5.075 10 5.075C10.55 5.075 11.0208 5.27083 11.4125 5.6625C11.8042 6.05417 12 6.525 12 7.075C12 7.625 11.8042 8.09583 11.4125 8.4875C11.0208 8.87917 10.55 9.075 10 9.075ZM14.25 11.325L12.825 9.9C13.1917 9.53333 13.4792 9.10833 13.6875 8.625C13.8958 8.14167 14 7.625 14 7.075C14 6.525 13.8958 6.00833 13.6875 5.525C13.4792 5.04167 13.1917 4.61667 12.825 4.25L14.25 2.825C14.7833 3.35833 15.2083 3.9875 15.525 4.7125C15.8417 5.4375 16 6.225 16 7.075C16 7.90833 15.8417 8.6875 15.525 9.4125C15.2083 10.1375 14.7833 10.775 14.25 11.325ZM17.075 14.15L15.65 12.725C16.3833 11.9917 16.9583 11.1417 17.375 10.175C17.7917 9.20833 18 8.175 18 7.075C18 5.95833 17.7917 4.91667 17.375 3.95C16.9583 2.98333 16.3833 2.14167 15.65 1.425L17.075 0C17.975 0.9 18.6875 1.95417 19.2125 3.1625C19.7375 4.37083 20 5.675 20 7.075C20 8.45833 19.7375 9.75417 19.2125 10.9625C18.6875 12.1708 17.975 13.2333 17.075 14.15Z" />
                            <TextBlock Text="알람" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RealtimeNavButton"
                            Tag="realtime"
                            Margin="0,0,0,8"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavigationButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Style="{StaticResource NavIconStyle}"
                                  Data="M0 18V16L2 14V18H0ZM4 18V12L6 10V18H4ZM8 18V10L10 12.025V18H8ZM12 18V12.025L14 10.025V18H12ZM16 18V8L18 6V18H16ZM0 12.825V10L7 3L11 7L18 0V2.825L11 9.825L7 5.825L0 12.825Z" />
                            <TextBlock Text="그래프" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="LogNavButton"
                            Tag="log"
                            Margin="0,0,0,8"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavigationButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Style="{StaticResource NavIconStyle}"
                                  Data="M2 16C1.45 16 0.979167 15.8042 0.5875 15.4125C0.195833 15.0208 0 14.55 0 14V2C0 1.45 0.195833 0.979167 0.5875 0.5875C0.979167 0.195833 1.45 0 2 0H18C18.55 0 19.0208 0.195833 19.4125 0.5875C19.8042 0.979167 20 1.45 20 2V14C20 14.55 19.8042 15.0208 19.4125 15.4125C19.0208 15.8042 18.55 16 18 16H2ZM2 14H18V4H2V14ZM5.5 13L4.1 11.6L6.675 9L4.075 6.4L5.5 5L9.5 9L5.5 13ZM10 13V11H16V13H10Z" />
                            <TextBlock Text="로그" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom"
                            Margin="22,0,22,24">
                    <Border Height="1"
                            Margin="-22,0,-22,16"
                            Background="#222832" />
                    <Button x:Name="SettingsNavButton"
                            Tag="settings"
                            Margin="0,0,0,8"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavigationButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Style="{StaticResource NavIconStyle}"
                                  Data="M4.25833 11.6667L4.025 9.8C3.89861 9.75139 3.77951 9.69306 3.66771 9.625C3.5559 9.55694 3.44653 9.48403 3.33958 9.40625L1.60417 10.1354L0 7.36458L1.50208 6.22708C1.49236 6.15903 1.4875 6.0934 1.4875 6.03021C1.4875 5.96701 1.4875 5.90139 1.4875 5.83333C1.4875 5.76528 1.4875 5.69965 1.4875 5.63646C1.4875 5.57326 1.49236 5.50764 1.50208 5.43958L0 4.30208L1.60417 1.53125L3.33958 2.26042C3.44653 2.18264 3.55833 2.10972 3.675 2.04167C3.79167 1.97361 3.90833 1.91528 4.025 1.86667L4.25833 0H7.46667L7.7 1.86667C7.82639 1.91528 7.94549 1.97361 8.05729 2.04167C8.1691 2.10972 8.27847 2.18264 8.38542 2.26042L10.1208 1.53125L11.725 4.30208L10.2229 5.43958C10.2326 5.50764 10.2375 5.57326 10.2375 5.63646C10.2375 5.69965 10.2375 5.76528 10.2375 5.83333C10.2375 5.90139 10.2375 5.96701 10.2375 6.03021C10.2375 6.0934 10.2278 6.15903 10.2083 6.22708L11.7104 7.36458L10.1062 10.1354L8.38542 9.40625C8.27847 9.48403 8.16667 9.55694 8.05 9.625C7.93333 9.69306 7.81667 9.75139 7.7 9.8L7.46667 11.6667H4.25833ZM5.27917 10.5H6.43125L6.63542 8.95417C6.93681 8.87639 7.21632 8.76215 7.47396 8.61146C7.7316 8.46076 7.96736 8.27847 8.18125 8.06458L9.625 8.6625L10.1938 7.67083L8.93958 6.72292C8.98819 6.58681 9.02222 6.4434 9.04167 6.29271C9.06111 6.14201 9.07083 5.98889 9.07083 5.83333C9.07083 5.67778 9.06111 5.52465 9.04167 5.37396C9.02222 5.22326 8.98819 5.07986 8.93958 4.94375L10.1938 3.99583L9.625 3.00417L8.18125 3.61667C7.96736 3.39306 7.7316 3.2059 7.47396 3.05521C7.21632 2.90451 6.93681 2.79028 6.63542 2.7125L6.44583 1.16667H5.29375L5.08958 2.7125C4.78819 2.79028 4.50868 2.90451 4.25104 3.05521C3.9934 3.2059 3.75764 3.38819 3.54375 3.60208L2.1 3.00417L1.53125 3.99583L2.78542 4.92917C2.73681 5.075 2.70278 5.22083 2.68333 5.36667C2.66389 5.5125 2.65417 5.66806 2.65417 5.83333C2.65417 5.98889 2.66389 6.13958 2.68333 6.28542C2.70278 6.43125 2.73681 6.57708 2.78542 6.72292L1.53125 7.67083L2.1 8.6625L3.54375 8.05C3.75764 8.27361 3.9934 8.46076 4.25104 8.61146C4.50868 8.76215 4.78819 8.87639 5.08958 8.95417L5.27917 10.5ZM5.89167 7.875C6.45556 7.875 6.93681 7.67569 7.33542 7.27708C7.73403 6.87847 7.93333 6.39722 7.93333 5.83333C7.93333 5.26944 7.73403 4.78819 7.33542 4.38958C6.93681 3.99097 6.45556 3.79167 5.89167 3.79167C5.31806 3.79167 4.83438 3.99097 4.44063 4.38958C4.04688 4.78819 3.85 5.26944 3.85 5.83333C3.85 6.39722 4.04688 6.87847 4.44063 7.27708C4.83438 7.67569 5.31806 7.875 5.89167 7.875Z" />
                            <TextBlock Text="설정" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SystemNavButton"
                            Tag="system"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavigationButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Style="{StaticResource NavIconStyle}"
                                  Data="M5.80417 9.33333C6.00833 9.33333 6.1809 9.26285 6.32188 9.12187C6.46285 8.9809 6.53333 8.80833 6.53333 8.60417C6.53333 8.4 6.46285 8.22743 6.32188 8.08646C6.1809 7.94549 6.00833 7.875 5.80417 7.875C5.6 7.875 5.42743 7.94549 5.28646 8.08646C5.14549 8.22743 5.075 8.4 5.075 8.60417C5.075 8.80833 5.14549 8.9809 5.28646 9.12187C5.42743 9.26285 5.6 9.33333 5.80417 9.33333ZM5.27917 7.0875H6.35833C6.35833 6.76667 6.39479 6.51389 6.46771 6.32917C6.54062 6.14444 6.74722 5.89167 7.0875 5.57083C7.34028 5.31806 7.53958 5.07743 7.68542 4.84896C7.83125 4.62049 7.90417 4.34583 7.90417 4.025C7.90417 3.48056 7.70486 3.0625 7.30625 2.77083C6.90764 2.47917 6.43611 2.33333 5.89167 2.33333C5.3375 2.33333 4.88785 2.47917 4.54271 2.77083C4.19757 3.0625 3.95694 3.4125 3.82083 3.82083L4.78333 4.2C4.83194 4.025 4.94132 3.83542 5.11146 3.63125C5.2816 3.42708 5.54167 3.325 5.89167 3.325C6.20278 3.325 6.43611 3.41007 6.59167 3.58021C6.74722 3.75035 6.825 3.9375 6.825 4.14167C6.825 4.33611 6.76667 4.5184 6.65 4.68854C6.53333 4.85868 6.3875 5.01667 6.2125 5.1625C5.78472 5.54167 5.52222 5.82847 5.425 6.02292C5.32778 6.21736 5.27917 6.57222 5.27917 7.0875ZM5.83333 11.6667C5.02639 11.6667 4.26806 11.5135 3.55833 11.2073C2.84861 10.901 2.23125 10.4854 1.70625 9.96042C1.18125 9.43542 0.765625 8.81806 0.459375 8.10833C0.153125 7.39861 0 6.64028 0 5.83333C0 5.02639 0.153125 4.26806 0.459375 3.55833C0.765625 2.84861 1.18125 2.23125 1.70625 1.70625C2.23125 1.18125 2.84861 0.765625 3.55833 0.459375C4.26806 0.153125 5.02639 0 5.83333 0C6.64028 0 7.39861 0.153125 8.10833 0.459375C8.81806 0.765625 9.43542 1.18125 9.96042 1.70625C10.4854 2.23125 10.901 2.84861 11.2073 3.55833C11.5135 4.26806 11.6667 5.02639 11.6667 5.83333C11.6667 6.64028 11.5135 7.39861 11.2073 8.10833C10.901 8.81806 10.4854 9.43542 9.96042 9.96042C9.43542 10.4854 8.81806 10.901 8.10833 11.2073C7.39861 11.5135 6.64028 11.6667 5.83333 11.6667ZM5.83333 10.5C7.13611 10.5 8.23958 10.0479 9.14375 9.14375C10.0479 8.23958 10.5 7.13611 10.5 5.83333C10.5 4.53056 10.0479 3.42708 9.14375 2.52292C8.23958 1.61875 7.13611 1.16667 5.83333 1.16667C4.53056 1.16667 3.42708 1.61875 2.52292 2.52292C1.61875 3.42708 1.16667 4.53056 1.16667 5.83333C1.16667 7.13611 1.61875 8.23958 2.52292 9.14375C3.42708 10.0479 4.53056 10.5 5.83333 10.5Z" />
                            <TextBlock Text="시스템" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1"
              Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="26" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource CardBrush}"
                    CornerRadius="10">
                <ItemsControl ItemsSource="{Binding StatusCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="24,14"
                                    BorderBrush="#31353C"
                                    BorderThickness="0,0,1,0">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Text="{Binding Title}" />
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,6,0,0">
                                        <TextBlock Foreground="{Binding Accent}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Summary}" />
                                        <TextBlock Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding Accent}"
                                                   FontSize="16"
                                                   Text="{Binding IconText}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="11"
                                               Text="{Binding Detail}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Grid Grid.Row="2">
                <Grid Visibility="{Binding DashboardViewVisibility}">
                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="390" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="26" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ItemsControl Grid.Row="0"
                                      ItemsSource="{Binding DashboardMetricCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,14,0"
                                            Padding="20,18"
                                            Background="{StaticResource CardBrush}"
                                            CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Title}"
                                                       TextWrapping="Wrap" />
                                            <StackPanel Margin="0,10,0,0"
                                                        Orientation="Horizontal">
                                                <TextBlock Foreground="{Binding Accent}"
                                                           FontSize="36"
                                                           FontWeight="Bold"
                                                           Text="{Binding Value}" />
                                                <TextBlock Margin="5,14,0,0"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="16"
                                                           Text="{Binding Unit}" />
                                            </StackPanel>
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="{Binding Accent}"
                                                       FontSize="12"
                                                       Text="{Binding Detail}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Grid.Row="2"
                                Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="맵" />

                                <Border Grid.Row="1"
                                        MinHeight="520"
                                        Margin="0,24,0,0"
                                        Background="{StaticResource CardLowBrush}"
                                        BorderBrush="#222832"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        ClipToBounds="True">
                                    <local:DynamometerRoomMapControl />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="3*" />
                            <RowDefinition Height="26" />
                            <RowDefinition Height="2*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="실시간 센서 피드" />
                                <ItemsControl Margin="0,16,0,0"
                                              ItemsSource="{Binding SensorFeedItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,6,6"
                                                    Padding="10,8"
                                                    Background="{StaticResource CardLowBrush}"
                                                    BorderBrush="{Binding Border}"
                                                    BorderThickness="2,0,0,0"
                                                    CornerRadius="5">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock Foreground="{StaticResource PrimaryTextBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Title}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock DockPanel.Dock="Right"
                                                                   Margin="4,0,0,0"
                                                                   Foreground="{Binding Accent}"
                                                                   FontSize="10"
                                                                   Text="{Binding StatusText}" />
                                                    </DockPanel>
                                                    <StackPanel Margin="0,4,0,0"
                                                                Orientation="Horizontal">
                                                        <TextBlock Foreground="{Binding Accent}"
                                                                   FontSize="18"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Value}" />
                                                        <TextBlock Margin="3,5,0,0"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="10"
                                                                   Text="{Binding Unit}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="이벤트 로그" />
                                <ScrollViewer Grid.Row="1"
                                              Margin="0,14,0,0"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding RecentEvents}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="12,10"
                                                        Background="{StaticResource CardLowBrush}"
                                                        BorderBrush="{Binding Accent}"
                                                        BorderThickness="2,0,0,0"
                                                        CornerRadius="5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="20" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Foreground="{Binding Accent}"
                                                                   FontWeight="Bold"
                                                                   Text="!" />
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Foreground="{StaticResource PrimaryTextBrush}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Message}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="12"
                                                                       Text="{Binding TimestampText}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                    </Grid>
                </Grid>

                <Grid Visibility="{Binding RealtimeViewVisibility}">
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="그래프" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding RealtimeSummary}" />
                            </StackPanel>
                            <Border Grid.Row="1"
                                    Margin="0,24,0,0"
                                    Background="{StaticResource CardLowBrush}"
                                    BorderBrush="#31353C"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Canvas Margin="36"
                                        ClipToBounds="True">
                                    <Polyline Points="{Binding TemperatureTrendPoints}"
                                              Stroke="{x:Static local:DashboardPalette.TempLine}"
                                              StrokeThickness="4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" />
                                    <Polyline Points="{Binding HumidityTrendPoints}"
                                              Stroke="{x:Static local:DashboardPalette.HumidityLine}"
                                              StrokeThickness="4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" />
                                </Canvas>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding HistoryViewVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="24"
                            Background="{StaticResource CardBrush}"
                            CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="조회 조건" />

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="0.9*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="0.9*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="1.2*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="조회 기간" />
                                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                        <DatePicker Width="170"
                                                    SelectedDate="{Binding SelectedReportDate}" />
                                        <TextBlock Margin="10,8"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="~" />
                                        <DatePicker Width="170"
                                                    SelectedDate="{Binding SelectedHistoryEndDate}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="저장주기" />
                                    <ComboBox Margin="0,8,0,0"
                                              ItemsSource="{Binding SamplingModes}"
                                              SelectedItem="{Binding SelectedSamplingMode}" />
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="채널 선택" />
                                    <ComboBox Margin="0,8,0,0"
                                              ItemsSource="{Binding HistoryChannelOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedHistoryChannelCode}" />
                                </StackPanel>

                                <StackPanel Grid.Column="6">
                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="위치 선택" />
                                    <ComboBox Margin="0,8,0,0"
                                              ItemsSource="{Binding HistoryLocationOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedHistoryLocationName}" />
                                </StackPanel>

                                <StackPanel Grid.Column="8">
                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="상태 필터" />
                                    <ComboBox Margin="0,8,0,0"
                                              ItemsSource="{Binding HistoryStatusOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedHistoryStatus}" />
                                </StackPanel>

                                <StackPanel Grid.Column="10">
                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="데이터 종류" />
                                    <ComboBox Margin="0,8,0,0"
                                              ItemsSource="{Binding HistoryKindOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedHistoryKind}" />
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="3"
                                    Height="1"
                                    Background="#31353C" />

                            <StackPanel Grid.Row="4"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                <Button Width="110"
                                        Margin="0,0,10,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ResetHistoryFiltersButton_Click"
                                        Content="초기화" />
                                <Button Width="140"
                                        Margin="0,0,10,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ExportReportCsvButton_Click"
                                        Content="CSV 내보내기" />
                                <Button Width="110"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="RefreshHistoryButton_Click"
                                        Content="조회" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <UniformGrid Grid.Row="2"
                                 Columns="6">
                        <Border Margin="0,0,14,0" Padding="18" Background="{StaticResource CardBrush}" BorderBrush="#31353C" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="조회 건수" />
                                <TextBlock Margin="0,8,0,0" Foreground="{StaticResource PrimaryTextBrush}" FontSize="24" FontWeight="SemiBold" Text="{Binding HistoryCountText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,14,0" Padding="18" Background="{StaticResource CardBrush}" BorderBrush="#31353C" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="최소값" />
                                <TextBlock Margin="0,8,0,0" Foreground="{StaticResource PrimaryTextBrush}" FontSize="24" FontWeight="SemiBold" Text="{Binding HistoryMinText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,14,0" Padding="18" Background="{StaticResource CardBrush}" BorderBrush="#31353C" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="최대값" />
                                <TextBlock Margin="0,8,0,0" Foreground="{StaticResource PrimaryTextBrush}" FontSize="24" FontWeight="SemiBold" Text="{Binding HistoryMaxText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,14,0" Padding="18" Background="{StaticResource CardBrush}" BorderBrush="#31353C" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="평균값" />
                                <TextBlock Margin="0,8,0,0" Foreground="{StaticResource PrimaryTextBrush}" FontSize="24" FontWeight="SemiBold" Text="{Binding HistoryAverageText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,14,0" Padding="18" Background="{StaticResource CardBrush}" BorderBrush="#31353C" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="마지막 수집" />
                                <TextBlock Margin="0,8,0,0" Foreground="{StaticResource PrimaryTextBrush}" FontSize="24" FontWeight="SemiBold" Text="{Binding HistoryLastSampleText}" />
                            </StackPanel>
                        </Border>
                        <Border Padding="18" Background="#211415" BorderBrush="#5C312D" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource WarnBrush}" FontSize="13" Text="알람 발생 건수" />
                                <TextBlock Margin="0,8,0,0" Foreground="{StaticResource WarnBrush}" FontSize="24" FontWeight="SemiBold" Text="{Binding HistoryAlarmCountText}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="340" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="#31353C"
                                BorderThickness="1"
                                CornerRadius="8">
                            <DataGrid ItemsSource="{Binding SampleHistoryItems}"
                                      SelectedItem="{Binding SelectedSampleHistoryItem}"
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="시각" Binding="{Binding SampledAt}" Width="180" />
                                    <DataGridTextColumn Header="채널명" Binding="{Binding ChannelCode}" Width="110" />
                                    <DataGridTextColumn Header="위치명" Binding="{Binding LocationName}" Width="160" />
                                    <DataGridTextColumn Header="데이터 종류" Binding="{Binding Kind}" Width="120" />
                                    <DataGridTextColumn Header="RAW 값" Binding="{Binding RawValue}" Width="110" />
                                    <DataGridTextColumn Header="보정값" Binding="{Binding CorrectedValue}" Width="110" />
                                    <DataGridTextColumn Header="단위" Binding="{Binding Unit}" Width="80" />
                                    <DataGridTextColumn Header="상태" Binding="{Binding Quality}" Width="100" />
                                    <DataGridTextColumn Header="알람 여부" Binding="{Binding AlarmText}" Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="24"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="#31353C"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource PrimaryTextBrush}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Text="상세 정보" />
                                <Border Margin="0,22,0,0"
                                        Padding="18"
                                        Background="{StaticResource CardHighBrush}"
                                        BorderBrush="#3A3F49"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MutedTextStyle}" Text="선택 행 데이터" />
                                            <TextBlock Margin="0,12,0,0" Foreground="{StaticResource PrimaryTextBrush}" FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedSampleHistoryItem.ChannelCode}" />
                                            <TextBlock Margin="0,8,0,0" Style="{StaticResource MutedTextStyle}" Text="{Binding SelectedSampleHistoryItem.SampledAt}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Foreground="{StaticResource PrimaryBrush}" FontSize="26" FontWeight="SemiBold" Text="{Binding SelectedSampleHistoryItem.CorrectedValue}" />
                                            <TextBlock Margin="6,9,0,0" Foreground="{StaticResource MutedTextBrush}" FontSize="13" Text="{Binding SelectedSampleHistoryItem.Unit}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Margin="0,18,0,0" Padding="18" Background="{StaticResource CardLowBrush}" BorderBrush="#31353C" BorderThickness="1" CornerRadius="6">
                                    <Grid>
                                        <TextBlock Foreground="{StaticResource PrimaryTextBrush}" Text="통신 상태" />
                                        <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource GoodBrush}" Text="{Binding SelectedSampleHistoryItem.Quality}" />
                                    </Grid>
                                </Border>

                                <Border Margin="0,18,0,0" Padding="18" Background="{StaticResource CardLowBrush}" BorderBrush="#31353C" BorderThickness="1" CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource PrimaryTextBrush}" Text="해당 시점 알람" />
                                        <TextBlock Margin="0,12,0,0" Style="{StaticResource MutedTextStyle}" Text="{Binding SelectedSampleHistoryItem.AlarmText}" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Margin="0,24,0,0" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" Text="비고 / 이벤트 메시지" />
                                <Border Margin="0,10,0,0" MinHeight="88" Padding="16" Background="{StaticResource CardLowBrush}" BorderBrush="#31353C" BorderThickness="1" CornerRadius="6">
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{Binding ReportExportStatusMessage}" TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Border Padding="24"
                        Background="{StaticResource CardBrush}"
                        CornerRadius="10"
                        Visibility="Collapsed">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,18">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <DatePicker Width="150"
                                            Margin="0,0,10,0"
                                            SelectedDate="{Binding SelectedReportDate}" />
                                <ComboBox Width="180"
                                          Margin="0,0,10,0"
                                          ItemsSource="{Binding HistoryChannelOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedHistoryChannelCode}" />
                                <Button Width="150"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="ExportReportCsvButton_Click"
                                        Content="CSV 내보내기" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="이력 조회" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding SampleHistorySummary}" />
                                <TextBlock Margin="0,4,0,0"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding ReportExportStatusMessage}" />
                            </StackPanel>
                        </DockPanel>

                        <DataGrid ItemsSource="{Binding SampleHistoryItems}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="시각" Binding="{Binding SampledAt}" Width="180" />
                                <DataGridTextColumn Header="채널" Binding="{Binding ChannelCode}" Width="150" />
                                <DataGridTextColumn Header="종류" Binding="{Binding Kind}" Width="100" />
                                <DataGridTextColumn Header="Raw" Binding="{Binding RawValue}" Width="120" />
                                <DataGridTextColumn Header="보정값" Binding="{Binding CorrectedValue}" Width="120" />
                                <DataGridTextColumn Header="상태" Binding="{Binding Quality}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Padding="24"
                        Background="{StaticResource CardBrush}"
                        CornerRadius="10"
                        Visibility="{Binding AlarmViewVisibility}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,18">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <DatePicker Width="150"
                                            Margin="0,0,10,0"
                                            SelectedDate="{Binding SelectedAlarmDate}" />
                                <ComboBox Width="180"
                                          Margin="0,0,10,0"
                                          ItemsSource="{Binding AlarmChannelOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedAlarmChannelCode}" />
                                <ComboBox Width="150"
                                          Margin="0,0,10,0"
                                          ItemsSource="{Binding AlarmStatusOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedAlarmStatus}" />
                                <Button Width="150"
                                        Margin="0,0,10,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        IsEnabled="{Binding CanAcknowledgeSelectedAlarm}"
                                        Click="AcknowledgeSelectedAlarmButton_Click"
                                        Content="선택 확인" />
                                <Button Width="150"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="AcknowledgeAllActiveAlarmsButton_Click"
                                        Content="전체 확인" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="알람" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding AlarmHistorySummary}" />
                            </StackPanel>
                        </DockPanel>

                        <DataGrid ItemsSource="{Binding AlarmHistoryItems}"
                                  SelectedItem="{Binding SelectedAlarmHistoryItem}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="발생 시각" Binding="{Binding OccurredAt}" Width="170" />
                                <DataGridTextColumn Header="확인 시각" Binding="{Binding AcknowledgedAt}" Width="170" />
                                <DataGridTextColumn Header="해제 시각" Binding="{Binding ResolvedAt}" Width="170" />
                                <DataGridTextColumn Header="채널" Binding="{Binding ChannelCode}" Width="140" />
                                <DataGridTextColumn Header="알람 종류" Binding="{Binding AlarmType}" Width="130" />
                                <DataGridTextColumn Header="심각도" Binding="{Binding Severity}" Width="100" />
                                <DataGridTextColumn Header="측정값" Binding="{Binding MeasuredValue}" Width="110" />
                                <DataGridTextColumn Header="메시지" Binding="{Binding Message}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Padding="24"
                        Background="{StaticResource CardBrush}"
                        CornerRadius="10"
                        Visibility="{Binding SettingsViewVisibility}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="설정" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding RuntimeSettingsFilePath}" />
                            <TextBlock Margin="0,4,0,18"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding EffectiveDataStoragePath}" />

                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{StaticResource PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="저장주기" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding SamplingModes}"
                                          SelectedItem="{Binding SelectedSamplingMode}" />
                                <TextBlock Grid.Column="2"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="데이터 경로" />
                                <TextBox Grid.Column="3"
                                         Text="{Binding SettingsDataRoot}" />
                            </Grid>

                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="장비 통신 설정" />
                            <DataGrid Margin="0,12,0,22"
                                      ItemsSource="{Binding DeviceSettingsItems}"
                                      IsReadOnly="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Key" Binding="{Binding Key}" IsReadOnly="True" Width="140" />
                                    <DataGridTextColumn Header="표시명" Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    <DataGridTextColumn Header="IP" Binding="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" Width="220" />
                                    <DataGridTextColumn Header="Port" Binding="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="채널 기준 설정" />
                            <DataGrid Margin="0,12,0,22"
                                      ItemsSource="{Binding ChannelSettingsItems}"
                                      IsReadOnly="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="채널" Binding="{Binding Code}" IsReadOnly="True" Width="110" />
                                    <DataGridTextColumn Header="표시명" Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                    <DataGridTextColumn Header="위치명" Binding="{Binding LocationName, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                    <DataGridTextColumn Header="목표값" Binding="{Binding TargetValue, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                                    <DataGridTextColumn Header="편차" Binding="{Binding DeviationThreshold, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                                    <DataGridTextColumn Header="하한" Binding="{Binding LowAlarmLimit, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                                    <DataGridTextColumn Header="상한" Binding="{Binding HighAlarmLimit, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                                    <DataGridTextColumn Header="Scale" Binding="{Binding CalibrationScale, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                    <DataGridTextColumn Header="Offset" Binding="{Binding Offset, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Width="120"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ReloadSettingsButton_Click"
                                        Content="다시 불러오기" />
                                <Button Width="120"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="SaveSettingsButton_Click"
                                        Content="설정 저장" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Padding="24"
                        Background="{StaticResource CardBrush}"
                        CornerRadius="10"
                        Visibility="{Binding LogViewVisibility}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="로그" />
                        <TextBlock Margin="0,8,0,20"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="최근 알람 및 시스템 이벤트를 확인합니다." />
                        <ItemsControl ItemsSource="{Binding RecentEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="16"
                                            Background="{StaticResource CardLowBrush}"
                                            BorderBrush="{Binding Accent}"
                                            BorderThickness="2,0,0,0"
                                            CornerRadius="5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding TimestampText}" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       Text="{Binding Message}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Padding="24"
                        Background="{StaticResource CardBrush}"
                        CornerRadius="10"
                        Visibility="{Binding SystemViewVisibility}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="시스템" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding RuntimeSettingsFilePath}" />
                        <TextBlock Margin="0,6,0,24"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding EffectiveDataStoragePath}" />
                        <ItemsControl ItemsSource="{Binding StatusCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,16,0"
                                            Padding="20"
                                            Background="{StaticResource CardLowBrush}"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding Title}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="{Binding Accent}"
                                                       FontSize="24"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Summary}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding Detail}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
