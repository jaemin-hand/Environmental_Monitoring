<Window x:Class="EnvironmentalMonitoring.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Environmental Monitoring"
        Width="1920"
        Height="1080"
        MinWidth="1280"
        MinHeight="720"
        Background="#07101B"
        FontFamily="{StaticResource PretendardVariable}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#07101B" />
        <SolidColorBrush x:Key="PanelBrush" Color="#101B2A" />
        <SolidColorBrush x:Key="PanelDeepBrush" Color="#07101A" />
        <SolidColorBrush x:Key="HeaderBrush" Color="#0C1625" />
        <SolidColorBrush x:Key="BorderBrush" Color="#3B516B" />
        <SolidColorBrush x:Key="SubtleBorderBrush" Color="#1B2B3E" />
        <SolidColorBrush x:Key="TextBrush" Color="#EFF4FF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B5BECF" />
        <SolidColorBrush x:Key="BlueBrush" Color="#55A2FF" />
        <SolidColorBrush x:Key="CyanBrush" Color="#43D0D0" />
        <SolidColorBrush x:Key="PurpleBrush" Color="#B482FF" />
        <SolidColorBrush x:Key="GreenBrush" Color="#65E178" />
        <SolidColorBrush x:Key="RedBrush" Color="#FF423B" />
        <SolidColorBrush x:Key="AmberBrush" Color="#FFB02E" />

        <LinearGradientBrush x:Key="PanelGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#142236" Offset="0" />
            <GradientStop Color="#08131F" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#101D31" Offset="0" />
            <GradientStop Color="#060D17" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AlarmGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2B1620" Offset="0" />
            <GradientStop Color="#492121" Offset="1" />
        </LinearGradientBrush>

        <DropShadowEffect x:Key="PanelShadow" BlurRadius="18" ShadowDepth="0" Color="#000000" Opacity="0.28" />
        <DropShadowEffect x:Key="BlueGlow" BlurRadius="14" ShadowDepth="0" Color="#287BFF" Opacity="0.38" />
        <DropShadowEffect x:Key="RedGlow" BlurRadius="16" ShadowDepth="0" Color="#FF2F25" Opacity="0.45" />

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelGradientBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
        </Style>

        <Style x:Key="AlarmCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelGradientBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="#3B516B" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasActiveAlarm}" Value="True">
                    <Setter Property="Background" Value="{StaticResource AlarmGradientBrush}" />
                    <Setter Property="Effect" Value="{StaticResource RedGlow}" />
                    <Setter Property="BorderBrush">
                        <Setter.Value>
                            <SolidColorBrush Color="#FF423B" />
                        </Setter.Value>
                    </Setter>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Name="AlarmCardBlinkStoryboard">
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                From="#FF423B"
                                                To="#8A211D"
                                                Duration="0:0:0.55"
                                                AutoReverse="True"
                                                RepeatBehavior="Forever" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <RemoveStoryboard BeginStoryboardName="AlarmCardBlinkStoryboard" />
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AlarmAccentTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasActiveAlarm}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,3" />
            <Setter Property="Padding" Value="42,0" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="Height" Value="44" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PeriodButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="#080C14" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActivePeriodButtonStyle" TargetType="Button" BasedOn="{StaticResource PeriodButtonStyle}">
            <Setter Property="Background" Value="#CBD4EF" />
            <Setter Property="Foreground" Value="#111827" />
        </Style>

        <Style x:Key="TinyCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SvgIconPathStyle" TargetType="Path">
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Fill" Value="Transparent" />
        </Style>

        <Style x:Key="GraphGridLineStyle" TargetType="Line">
            <Setter Property="Stroke" Value="#1A2635" />
            <Setter Property="StrokeThickness" Value="0.7" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="GraphAxisLineStyle" TargetType="Line">
            <Setter Property="Stroke" Value="#54677E" />
            <Setter Property="StrokeThickness" Value="1.1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="GraphAxisTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#718096" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#718096" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <DataTemplate x:Key="CalibrationRowTemplate">
            <Border Background="#070B12"
                    BorderBrush="#1E334C"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8"
                    Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="82" />
                        <ColumnDefinition Width="98" />
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="142" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="134" />
                        <ColumnDefinition Width="134" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding KindText}"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="14"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding LocationName}"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding CurrentValueText}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="15"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4"
                               Text="{Binding ExistingOffsetText}"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="15"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="5"
                             Text="{Binding ReferenceValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             Margin="0,0,16,0"
                             Padding="10,0"
                             Background="#D8DCE7"
                             Foreground="#111827"
                             BorderBrush="#8C95A8"
                             BorderThickness="1"
                             FontSize="15"
                             VerticalContentAlignment="Center" />
                    <TextBlock Grid.Column="6"
                               Text="{Binding NewOffsetText}"
                               Foreground="{StaticResource BlueBrush}"
                               FontSize="15"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="7"
                               Text="{Binding PreviewValueText}"
                               Foreground="{StaticResource GreenBrush}"
                               FontSize="15"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="8"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding QualityText}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13"
                                   Margin="0,0,12,0" />
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{Binding StatusBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SensorCardTemplate">
            <Border Background="#070B12"
                    BorderBrush="{Binding Border}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding Title}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <Viewbox Grid.Column="1"
                             Width="20"
                             Height="20"
                             Margin="0,-1,0,0">
                        <Path Data="M7.5 12L10.5 15L16.5 9M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z"
                              Stroke="{Binding Accent}"
                              Style="{StaticResource SvgIconPathStyle}" />
                    </Viewbox>

                    <StackPanel Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding Value}"
                                   Foreground="{Binding Accent}"
                                   FontSize="25"
                                   FontWeight="Light" />
                        <TextBlock Text="{Binding Unit}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="12"
                                   Margin="4,11,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="EventRowTemplate">
            <Border BorderBrush="#1D2E43"
                    BorderThickness="0,0,0,1"
                    Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="86" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="!"
                               Foreground="{Binding Accent}"
                               FontSize="17"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding TimestampText, Mode=OneWay}"
                               Foreground="{Binding Accent}"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Message, Mode=OneWay}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="15"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3"
                               Text="-"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="15"
                               HorizontalAlignment="Right" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="1920"
              Height="1080"
              Background="{StaticResource BgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="62" />
                <RowDefinition Height="48" />
                <RowDefinition Height="128" />
                <RowDefinition Height="342" />
                <RowDefinition Height="218" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource HeaderGradientBrush}"
                    BorderBrush="#18263A"
                    BorderThickness="0,0,0,1"
                    Padding="24,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="샤시 다이나모 환경 모니터링 시스템"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="27"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Viewbox Width="28"
                                 Height="28"
                                 Margin="0,0,10,0"
                                 VerticalAlignment="Center">
                            <Path Data="M21 5C21 6.65685 16.9706 8 12 8C7.02944 8 3 6.65685 3 5M21 5C21 3.34315 16.9706 2 12 2C7.02944 2 3 3.34315 3 5M21 5V19C21 20.66 17 22 12 22C7 22 3 20.66 3 19V5M21 12C21 13.66 17 15 12 15C7 15 3 13.66 3 12"
                                  Stroke="{StaticResource GreenBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Uniform" />
                        </Viewbox>
                        <TextBlock Text="{Binding LastStorageWriteText}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                        <Border Width="1"
                                Height="28"
                                Background="#314059"
                                Margin="26,0" />
                        <TextBlock Text="{Binding CurrentTimeText}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="20"
                                   Width="138"
                                   TextAlignment="Right"
                                   Typography.NumeralAlignment="Tabular"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#111823"
                    BorderBrush="#253246"
                    BorderThickness="0,0,0,1"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Margin="24,0,0,0">
                    <Button x:Name="DashboardNavButton"
                            Tag="dashboard"
                            Content="실시간 대시보드"
                            Style="{StaticResource TopNavButtonStyle}"
                            Click="NavigationButton_Click" />
                    <Button x:Name="HistoryNavButton"
                            Tag="history"
                            Content="히스토리 조회"
                            Style="{StaticResource TopNavButtonStyle}"
                            Click="NavigationButton_Click" />
                    <Button x:Name="AlarmNavButton"
                            Tag="alarm"
                            Content="알람 관리"
                            Style="{StaticResource TopNavButtonStyle}"
                            Click="NavigationButton_Click" />
                    <Button x:Name="SettingsNavButton"
                            Tag="settings"
                            Content="임계값 설정"
                            Style="{StaticResource TopNavButtonStyle}"
                            Click="NavigationButton_Click" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="2"
                  Margin="24,12,24,0"
                  Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource PanelStyle}"
                        BorderBrush="{StaticResource BlueBrush}">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Viewbox Width="54"
                                 Height="54"
                                 VerticalAlignment="Center">
                            <Path Data="M21 3L15 3M21 7L15 7M21 11L15 11M5.5 13.7578V4.5C5.5 3.11929 6.61929 2 8 2C9.38071 2 10.5 3.11929 10.5 4.5V13.7578C11.706 14.565 12.5 15.9398 12.5 17.5C12.5 19.9853 10.4853 22 8 22C5.51472 22 3.5 19.9853 3.5 17.5C3.5 15.9398 4.29401 14.565 5.5 13.7578ZM9 17.5C9 18.0523 8.55228 18.5 8 18.5C7.44772 18.5 7 18.0523 7 17.5C7 16.9477 7.44772 16.5 8 16.5C8.55228 16.5 9 16.9477 9 17.5Z"
                                  Stroke="{StaticResource BlueBrush}"
                                  Style="{StaticResource SvgIconPathStyle}" />
                        </Viewbox>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="평균 온도" Foreground="{StaticResource TextBrush}" FontSize="17" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="{Binding DashboardMetricCards[0].Value}" Foreground="{StaticResource TextBrush}" FontSize="36" FontWeight="Light" />
                                <TextBlock Text="°C" Foreground="{StaticResource TextBrush}" FontSize="28" Margin="8,7,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="24" Height="24" Margin="0,0,8,0">
                                <Path Data="M7.5 12L10.5 15L16.5 9M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z"
                                      Stroke="{StaticResource GreenBrush}"
                                      Style="{StaticResource SvgIconPathStyle}" />
                            </Viewbox>
                            <TextBlock Text="정상 범위" Foreground="{StaticResource TextBrush}" FontSize="16" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource PanelStyle}"
                        BorderBrush="{StaticResource CyanBrush}">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Viewbox Width="46"
                                 Height="46"
                                 VerticalAlignment="Center">
                            <Path Data="M5.51667 11.3333C5.65 11.3222 5.76389 11.2694 5.85833 11.175C5.95278 11.0806 6 10.9667 6 10.8333C6 10.6778 5.95 10.5528 5.85 10.4583C5.75 10.3639 5.62222 10.3222 5.46667 10.3333C5.01111 10.3667 4.52778 10.2417 4.01667 9.95833C3.50556 9.675 3.18333 9.16111 3.05 8.41667C3.02778 8.29445 2.96944 8.19444 2.875 8.11667C2.78056 8.03889 2.67222 8 2.55 8C2.39444 8 2.26667 8.05833 2.16667 8.175C2.06667 8.29167 2.03333 8.42778 2.06667 8.58333C2.25556 9.59444 2.7 10.3167 3.4 10.75C4.1 11.1833 4.80556 11.3778 5.51667 11.3333ZM5.33333 13.3333C3.81111 13.3333 2.54167 12.8111 1.525 11.7667C0.508333 10.7222 0 9.42222 0 7.86667C0 6.75556 0.441667 5.54722 1.325 4.24167C2.20833 2.93611 3.54444 1.52222 5.33333 0C7.12222 1.52222 8.45833 2.93611 9.34167 4.24167C10.225 5.54722 10.6667 6.75556 10.6667 7.86667C10.6667 9.42222 10.1583 10.7222 9.14167 11.7667C8.125 12.8111 6.85556 13.3333 5.33333 13.3333ZM5.33333 12C6.48889 12 7.44444 11.6083 8.2 10.825C8.95555 10.0417 9.33333 9.05556 9.33333 7.86667C9.33333 7.05556 8.99722 6.13889 8.325 5.11667C7.65278 4.09444 6.65556 2.97778 5.33333 1.76667C4.01111 2.97778 3.01389 4.09444 2.34167 5.11667C1.66944 6.13889 1.33333 7.05556 1.33333 7.86667C1.33333 9.05556 1.71111 10.0417 2.46667 10.825C3.22222 11.6083 4.17778 12 5.33333 12Z"
                                  Fill="{StaticResource CyanBrush}"
                                  Stretch="Uniform" />
                        </Viewbox>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="평균 습도" Foreground="{StaticResource TextBrush}" FontSize="17" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="{Binding DashboardMetricCards[1].Value}" Foreground="{StaticResource TextBrush}" FontSize="36" FontWeight="Light" />
                                <TextBlock Text="%" Foreground="{StaticResource TextBrush}" FontSize="28" Margin="8,7,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="24" Height="24" Margin="0,0,8,0">
                                <Path Data="M7.5 12L10.5 15L16.5 9M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z"
                                      Stroke="{StaticResource GreenBrush}"
                                      Style="{StaticResource SvgIconPathStyle}" />
                            </Viewbox>
                            <TextBlock Text="정상 범위" Foreground="{StaticResource TextBrush}" FontSize="16" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource PanelStyle}"
                        BorderBrush="{StaticResource PurpleBrush}">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Viewbox Width="46"
                                 Height="46"
                                 VerticalAlignment="Center">
                            <Path Data="M0 8.66667V7.33333H10.6667V8.66667H0V8.66667M0 6.66667V5.33333H10.6667V6.66667H0V6.66667M4.66667 14V11.8667L3.6 12.9333L2.66667 12L5.33333 9.33333L8 12L7.06667 12.9333L6 11.9V14H4.66667V14M5.33333 4.66667L2.66667 2L3.6 1.06667L4.66667 2.13333V0H6V2.13333L7.06667 1.06667L8 2L5.33333 4.66667V4.66667"
                                  Fill="{StaticResource PurpleBrush}"
                                  Stretch="Uniform" />
                        </Viewbox>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="평균 대기압" Foreground="{StaticResource TextBrush}" FontSize="17" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="{Binding DashboardMetricCards[2].Value}" Foreground="{StaticResource TextBrush}" FontSize="36" FontWeight="Light" />
                                <TextBlock Text="kPa" Foreground="{StaticResource TextBrush}" FontSize="28" Margin="8,7,0,0" />
                            </StackPanel>
                        </StackPanel>
