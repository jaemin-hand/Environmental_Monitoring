                                            ClipToBounds="True">
                                        <!-- Time/value grid -->
                                        <Line X1="0" Y1="65" X2="760" Y2="65" Style="{StaticResource GraphGridLineStyle}" />
                                        <Line X1="0" Y1="117" X2="760" Y2="117" Style="{StaticResource GraphGridLineStyle}" />
                                        <Line X1="0" Y1="170" X2="760" Y2="170" Style="{StaticResource GraphGridLineStyle}" />
                                        <Line X1="80" Y1="44" X2="80" Y2="200" Style="{StaticResource GraphGridLineStyle}" />
                                        <Line X1="240" Y1="44" X2="240" Y2="200" Style="{StaticResource GraphGridLineStyle}" />
                                        <Line X1="400" Y1="44" X2="400" Y2="200" Style="{StaticResource GraphGridLineStyle}" />
                                        <Line X1="560" Y1="44" X2="560" Y2="200" Style="{StaticResource GraphGridLineStyle}" />
                                        <Line X1="720" Y1="44" X2="720" Y2="200" Style="{StaticResource GraphGridLineStyle}" />
                                        <Line X1="0" Y1="44" X2="0" Y2="200" Style="{StaticResource GraphAxisLineStyle}" />
                                        <Line X1="0" Y1="200" X2="760" Y2="200" Style="{StaticResource GraphAxisLineStyle}" />

                                        <TextBlock Canvas.Left="8" Canvas.Top="53" Text="105.0" Style="{StaticResource GraphAxisTextStyle}" />
                                        <TextBlock Canvas.Left="8" Canvas.Top="105" Text="100.0" Style="{StaticResource GraphAxisTextStyle}" />
                                        <TextBlock Canvas.Left="8" Canvas.Top="171" Text="96.0 kPa" Style="{StaticResource GraphAxisTextStyle}" />

                                        <TextBlock Canvas.Left="54" Canvas.Top="202" Text="{Binding GraphTimeStartText}" Style="{StaticResource GraphAxisTextStyle}" />
                                        <TextBlock Canvas.Left="214" Canvas.Top="202" Text="{Binding GraphTimeQuarterText}" Style="{StaticResource GraphAxisTextStyle}" />
                                        <TextBlock Canvas.Left="374" Canvas.Top="202" Text="{Binding GraphTimeMiddleText}" Style="{StaticResource GraphAxisTextStyle}" />
                                        <TextBlock Canvas.Left="534" Canvas.Top="202" Text="{Binding GraphTimeThreeQuarterText}" Style="{StaticResource GraphAxisTextStyle}" />
                                        <TextBlock Canvas.Left="686" Canvas.Top="202" Text="{Binding GraphTimeEndText}" Style="{StaticResource GraphAxisTextStyle}" />

                                        <Polyline Stroke="#B482FF"
                                                  StrokeThickness="1.5"
                                                  StrokeLineJoin="Round"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Points="0,132 48,130 96,133 144,126 192,129 240,124 288,128 336,121 384,126 432,120 480,125 528,118 576,124 624,121 672,126 720,122 760,124" />
                                        <Line X1="0"
                                              Y1="65"
                                              X2="760"
                                              Y2="65"
                                              Stroke="#E07B79"
                                              StrokeThickness="1.2"
                                              StrokeDashArray="5,4" />
                                        <Line X1="0"
                                              Y1="170"
                                              X2="760"
                                              Y2="170"
                                              Stroke="#5B89E8"
                                              StrokeThickness="1.2"
                                              StrokeDashArray="5,4" />
                                        <TextBlock Canvas.Left="664"
                                                   Canvas.Top="40"
                                                   Text="105.0 kPa"
                                                   Foreground="#E07B79"
                                                   FontSize="18" />
                                        <TextBlock Canvas.Left="664"
                                                   Canvas.Top="176"
                                                   Text="96.0 kPa"
                                                   Foreground="#5B89E8"
                                                   FontSize="18" />
                                    </Canvas>
                                </Viewbox>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Blocking calibration modal: first-stage one-point offset calibration. -->
            <Grid Grid.Row="0"
                  Grid.RowSpan="6"
                  Panel.ZIndex="110"
                  Background="#C8000000"
                  Visibility="{Binding CalibrationModalVisibility}">
                <Border Width="1640"
                        Height="820"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#0A1422"
                        BorderBrush="#526A88"
                        BorderThickness="1.2"
                        CornerRadius="12"
                        Padding="28,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="58" />
                            <RowDefinition Height="58" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="64" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="캘리브레이션 설정"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="28"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="1점 Offset 보정"
                                           Foreground="{StaticResource BlueBrush}"
                                           FontSize="17"
                                           Margin="18,10,0,0" />
                            </StackPanel>
                            <Button Content="×"
                                    Click="CloseCalibrationModalButton_Click"
                                    Width="42"
                                    Height="42"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    Foreground="{StaticResource TextBrush}"
                                    BorderThickness="0"
                                    FontSize="32"
                                    Cursor="Hand" />
                        </Grid>

                        <Border Grid.Row="1"
                                Background="#07111E"
                                BorderBrush="#203A58"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18,10"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="현재 측정값과 기준 장비값을 비교해 채널별 Offset을 계산합니다."
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="계산식: 신규 Offset = 기존 Offset + 기준값 - 현재값 / 기준값을 입력한 채널만 저장됩니다."
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="14"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="Scale/Span 교정은 2차 단계에서 분리 적용"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="#2A4360"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="42" />
                                    <RowDefinition Height="38" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="전체 센서 Offset 교정"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="22"
                                           FontWeight="SemiBold" />

                                <Border Grid.Row="1"
                                        Background="#101824"
                                        BorderBrush="#1E334C"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="98" />
                                            <ColumnDefinition Width="190" />
                                            <ColumnDefinition Width="142" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="134" />
                                            <ColumnDefinition Width="134" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="채널" Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="종류" Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="2" Text="위치" Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="3" Text="현재값" Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="4" Text="기존 Offset" Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="5" Text="기준값 입력" Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="6" Text="신규 Offset" Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="7" Text="보정 후 값" Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="8" Text="상태" Style="{StaticResource TableHeaderTextStyle}" />
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="2"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Margin="0,8,0,0">
                                    <ItemsControl ItemsSource="{Binding CalibrationItems}"
                                                  ItemTemplate="{StaticResource CalibrationRowTemplate}" />
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3"
                              Margin="0,16,0,0">
                            <TextBlock Text="검교정 성적서 또는 기준 계측기 값을 기준값 입력란에 넣은 뒤 Offset 저장을 실행합니다."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Content="입력 초기화"
                                        Click="ResetCalibrationInputsButton_Click"
                                        Width="130"
                                        Height="40"
                                        Background="#293241"
                                        Foreground="{StaticResource TextBrush}"
                                        BorderBrush="#3A4658"
                                        BorderThickness="1"
                                        Margin="0,0,10,0"
                                        Cursor="Hand" />
                                <Button Content="닫기"
                                        Click="CloseCalibrationModalButton_Click"
                                        Width="110"
                                        Height="40"
                                        Background="#111827"
                                        Foreground="{StaticResource TextBrush}"
                                        BorderBrush="#526A88"
                                        BorderThickness="1"
                                        Margin="0,0,10,0"
                                        Cursor="Hand" />
                                <Button Content="Offset 저장"
                                        Click="SaveCalibrationButton_Click"
                                        Width="140"
                                        Height="40"
                                        Background="#0B2346"
                                        Foreground="{StaticResource BlueBrush}"
                                        BorderBrush="#2D64A0"
                                        BorderThickness="1"
                                        Cursor="Hand" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Blocking history modal: query conditions, graph, and CSV export only. -->
            <Grid Grid.Row="0"
                  Grid.RowSpan="6"
                  Panel.ZIndex="100"
                  Background="#C8000000"
                  Visibility="{Binding HistoryModalVisibility}">
                <Border Width="1680"
                        Height="820"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#0A1422"
                        BorderBrush="#526A88"
                        BorderThickness="1.2"
                        CornerRadius="12"
                        Padding="26"
                        Effect="{StaticResource PanelShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="54" />
                            <RowDefinition Height="104" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="히스토리 조회"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="27"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="DB 저장 데이터 기준"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="15"
                                           Margin="16,7,0,0" />
                            </StackPanel>
                            <Button Content="×"
                                    Click="CloseHistoryModalButton_Click"
                                    Width="42"
                                    Height="42"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="#101D2D"
                                    Foreground="{StaticResource TextBrush}"
                                    BorderBrush="#405675"
                                    BorderThickness="1"
                                    FontSize="27"
                                    Cursor="Hand" />
                        </Grid>

                        <Border Grid.Row="1"
                                Style="{StaticResource PanelStyle}"
                                Padding="22,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="118" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="176" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="조회 기간"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="17"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0" />
                                <DatePicker Grid.Column="1"
                                            SelectedDate="{Binding SelectedReportDate, Mode=TwoWay}"
                                            Height="42"
                                            Background="#07101A"
                                            Foreground="#111827"
                                            BorderBrush="#2E4C75"
                                            BorderThickness="1"
                                            FontSize="16"
                                            VerticalContentAlignment="Center" />
                                <TextBlock Grid.Column="5"
                                           Text="센서"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="17"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0" />
                                <ComboBox Grid.Column="6"
                                          ItemsSource="{Binding HistoryChannelOptions}"
                                          SelectedValue="{Binding SelectedHistoryChannelCode, Mode=TwoWay}"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="Label"
                                          Height="42"
                                          Background="#07101A"
                                          Foreground="#111827"
                                          BorderBrush="#2E4C75"
                                          BorderThickness="1"
                                          FontSize="16"
                                          Padding="10,0" />
                                <Button Grid.Column="8"
                                        Content="조회"
                                        Click="RefreshHistoryButton_Click"
                                        Height="42"
                                        Background="#0B2346"
                                        Foreground="{StaticResource BlueBrush}"
                                        BorderBrush="{StaticResource BlueBrush}"
                                        BorderThickness="1"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Cursor="Hand" />
                                <Button Grid.Column="10"
                                        Content="CSV 내보내기"
                                        Click="ExportReportCsvButton_Click"
                                        Height="42"
                                        Background="#0B1832"
                                        Foreground="{StaticResource BlueBrush}"
                                        BorderBrush="#315BCA"
                                        BorderThickness="1"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Cursor="Hand" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Style="{StaticResource PanelStyle}"
                                Padding="26,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="42" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="히스토리 그래프"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="22"
                                           FontWeight="SemiBold" />

                                <Border Grid.Row="1"
                                        Background="{StaticResource PanelDeepBrush}"
                                        BorderBrush="#203A58"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="22,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="52" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="°C" Foreground="{StaticResource MutedTextBrush}" FontSize="15" />
                                            <TextBlock Text="90" Foreground="{StaticResource MutedTextBrush}" FontSize="15" Margin="0,52,0,0" />
                                            <TextBlock Text="70" Foreground="{StaticResource MutedTextBrush}" FontSize="15" Margin="0,68,0,0" />
                                            <TextBlock Text="50" Foreground="{StaticResource MutedTextBrush}" FontSize="15" Margin="0,68,0,0" />
                                            <TextBlock Text="30" Foreground="{StaticResource MutedTextBrush}" FontSize="15" Margin="0,68,0,0" />
                                        </StackPanel>

                                        <Grid Grid.Column="1">
                                            <Viewbox Stretch="Fill"
                                                     Margin="0,0,0,30">
                                                <Canvas Width="760" Height="220">
                                                    <Line X1="0" Y1="22" X2="760" Y2="22" Stroke="#19304A" StrokeThickness="1" StrokeDashArray="3,4" />
                                                    <Line X1="0" Y1="70" X2="760" Y2="70" Stroke="#19304A" StrokeThickness="1" StrokeDashArray="3,4" />
                                                    <Line X1="0" Y1="118" X2="760" Y2="118" Stroke="#19304A" StrokeThickness="1" StrokeDashArray="3,4" />
                                                    <Line X1="0" Y1="166" X2="760" Y2="166" Stroke="#19304A" StrokeThickness="1" StrokeDashArray="3,4" />
                                                    <Line X1="0" Y1="22" X2="0" Y2="214" Style="{StaticResource GraphAxisLineStyle}" />
                                                    <Line X1="0" Y1="214" X2="760" Y2="214" Style="{StaticResource GraphAxisLineStyle}" />
                                                    <Line X1="110" Y1="22" X2="110" Y2="214" Stroke="#162B43" StrokeThickness="1" StrokeDashArray="3,4" />
                                                    <Line X1="240" Y1="22" X2="240" Y2="214" Stroke="#162B43" StrokeThickness="1" StrokeDashArray="3,4" />
                                                    <Line X1="380" Y1="22" X2="380" Y2="214" Stroke="#162B43" StrokeThickness="1" StrokeDashArray="3,4" />
                                                    <Line X1="520" Y1="22" X2="520" Y2="214" Stroke="#162B43" StrokeThickness="1" StrokeDashArray="3,4" />
                                                    <Line X1="670" Y1="22" X2="670" Y2="214" Stroke="#162B43" StrokeThickness="1" StrokeDashArray="3,4" />

                                                    <Polyline Points="{Binding HistoryTemperatureTrendPoints}"
                                                              Stroke="{StaticResource BlueBrush}"
                                                              StrokeThickness="2"
                                                              StrokeLineJoin="Round"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round" />
                                                </Canvas>
                                            </Viewbox>

                                            <TextBlock Text="{Binding SelectedReportDate, StringFormat={}{0:yyyy-MM-dd}}"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Bottom"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="15" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <StackPanel Visibility="Collapsed">
                <Button Tag="realtime" Click="NavigationButton_Click" />
                <Button Tag="log" Click="NavigationButton_Click" />
                <Button Tag="system" Click="NavigationButton_Click" />
            </StackPanel>
        </Grid>
    </Viewbox>
</Window>
